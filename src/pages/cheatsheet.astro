---
/**
 * 语法速查独立页面
 * 左侧模块导航侧边栏 + 右侧文档风格内容区
 * 布局与文档页完全一致：面包屑、doc-page 容器、prose 正文区
 */
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import CheatSheetPage from '@/islands/CheatSheetPage.vue'

// 导入所有速查表 JSON 数据
import gitData from '@/data/cheatsheets/git.json'
import javascriptData from '@/data/cheatsheets/javascript.json'
import typescriptData from '@/data/cheatsheets/typescript.json'
import pythonData from '@/data/cheatsheets/python.json'
import mysqlData from '@/data/cheatsheets/mysql.json'
import postgresqlData from '@/data/cheatsheets/postgresql.json'
import redisData from '@/data/cheatsheets/redis.json'
import vue3Data from '@/data/cheatsheets/vue3.json'
import linuxData from '@/data/cheatsheets/linux.json'

// 模块分类颜色（与首页一致）
const C = {
  toolchain: '#4f5bd5',
  'dev-lang': '#d63031',
  database: '#00b894',
  'comp-sci': '#8854d0',
  'eng-infra': '#e05a2b',
  data: '#f9a825',
}

// 所有速查数据，键为模块标识
const allData = {
  git: gitData,
  javascript: javascriptData,
  typescript: typescriptData,
  python: pythonData,
  mysql: mysqlData,
  postgresql: postgresqlData,
  redis: redisData,
  vue3: vue3Data,
  linux: linuxData,
}

// 模块元信息（标签名、图标、颜色、搜索占位符）
const moduleInfo = [
  { key: 'git', label: 'Git', icon: 'Git', color: C.toolchain, placeholder: '例如：clone、commit、branch...' },
  { key: 'javascript', label: 'JavaScript', icon: 'JS', color: C['dev-lang'], placeholder: '例如：Array、Promise、async...' },
  { key: 'typescript', label: 'TypeScript', icon: 'TS', color: C['dev-lang'], placeholder: '例如：interface、type、generic...' },
  { key: 'python', label: 'Python', icon: 'Py', color: C['dev-lang'], placeholder: '例如：list、dict、class...' },
  { key: 'mysql', label: 'MySQL', icon: 'My', color: C.database, placeholder: '例如：SELECT、JOIN、INDEX...' },
  { key: 'postgresql', label: 'PostgreSQL', icon: 'PG', color: C.database, placeholder: '例如：SELECT、JSONB、CTE...' },
  { key: 'redis', label: 'Redis', icon: 'Rd', color: C.database, placeholder: '例如：SET、GET、HSET...' },
  { key: 'vue3', label: 'Vue 3', icon: 'V3', color: C['dev-lang'], placeholder: '例如：ref、computed、watch...' },
  { key: 'linux', label: 'Linux', icon: 'Lx', color: C['eng-infra'], placeholder: '例如：ls、grep、chmod...' },
]

const base = import.meta.env.BASE_URL

// 面包屑导航数据
const breadcrumb = [
  { label: '首页', href: `${base}` },
  { label: '语法速查' },
]
---

<Layout title="语法速查">
  <SEO slot="head" title="语法速查 - FANDEX" description="常用命令与语法速查表，覆盖 Git、JavaScript、TypeScript、Python、MySQL、PostgreSQL、Redis、Vue 3、Linux 等模块" type="website" />

  <!-- 左侧模块导航侧边栏 -->
  <aside slot="sidebar" class="app-sidebar cheatsheet-sidebar" id="cheatsheet-sidebar">
    <nav class="sidebar-nav">
      <!-- 侧边栏顶部：标题和返回链接 -->
      <div class="sidebar-top">
        <div class="sidebar-module-header">
          <div class="sidebar-module-title-group">
            <span class="sidebar-module-color-bar" style="background: var(--color-primary)"></span>
            <span class="sidebar-module-title">语法速查</span>
          </div>
        </div>
        <a href={base} class="sidebar-back">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
            <polyline points="18 6 6 12 18 18" />
          </svg>
          <span>返回首页</span>
        </a>
      </div>

      <!-- 模块列表 -->
      <div class="sidebar-scroll">
        <ul class="file-list">
          {moduleInfo.map(mod => (
            <li>
              <a
                href={`#${mod.key}`}
                class="sidebar-file-link cheatsheet-module-link"
                data-module={mod.key}
              >
                <span class="module-dot" style={`background:${mod.color}`}></span>
                {mod.label}
              </a>
            </li>
          ))}
        </ul>
      </div>
    </nav>
  </aside>

  <!-- 右侧内容区：与文档页一致的 doc-page 布局 -->
  <div class="doc-page">
    <!-- 面包屑导航 -->
    <Breadcrumb items={breadcrumb} hasSidebar />

    <!-- 文章主体：使用 prose 样式 -->
    <article class="prose" style="--module-color: var(--color-primary)">
      <!-- 标题行：与文档页一致 -->
      <div class="doc-title-row">
        <h1 class="doc-title">语法速查</h1>
      </div>
      <!-- 文档头部元信息 -->
      <header class="doc-header">
        <p class="doc-description">常用命令与语法速查表，覆盖 9 个模块，支持搜索过滤、代码复制、分组折叠</p>
      </header>

      <!-- 速查表组件 -->
      <CheatSheetPage
        所有数据={allData}
        模块信息={moduleInfo}
        client:load
      />
    </article>
  </div>
</Layout>

<style>
/* 速查页侧边栏样式 */
.cheatsheet-sidebar {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.cheatsheet-sidebar .sidebar-nav {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

.cheatsheet-sidebar .sidebar-top {
  flex-shrink: 0;
  background: var(--color-bg-sidebar);
}

.cheatsheet-sidebar .sidebar-module-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-xs);
}

.cheatsheet-sidebar .sidebar-module-title-group {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  min-width: 0;
}

.cheatsheet-sidebar .sidebar-module-color-bar {
  width: 4px;
  height: 18px;
  border-radius: 2px;
  flex-shrink: 0;
}

.cheatsheet-sidebar .sidebar-module-title {
  font-family: var(--font-display);
  font-size: 0.85em;
  font-weight: 600;
  color: var(--color-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.cheatsheet-sidebar .sidebar-back {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: 0.8em;
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: var(--spacing-xs);
  text-decoration: none;
}

.cheatsheet-sidebar .sidebar-back:hover {
  color: var(--color-primary);
}

.cheatsheet-sidebar .sidebar-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

/* 模块导航链接 */
.cheatsheet-module-link {
  display: flex !important;
  align-items: center;
  gap: 8px;
}

/* 模块分类颜色圆点 */
.module-dot {
  width: 8px;
  height: 8px;
  border-radius: 50%;
  flex-shrink: 0;
}

/* 当前选中模块高亮 */
.cheatsheet-module-link.active {
  color: var(--color-primary);
  background: var(--color-bg-hover);
  font-weight: 600;
}
</style>

<script>
  // ========== 速查页侧边栏模块导航 ==========
  /** 根据当前 hash 更新侧边栏激活状态 */
  function updateActiveModule() {
    const hash = window.location.hash.slice(1)
    document.querySelectorAll('.cheatsheet-module-link').forEach(link => {
      const el = link as HTMLElement
      const mod = el.getAttribute('data-module')
      if (mod === hash) {
        el.classList.add('active')
      } else {
        el.classList.remove('active')
      }
    })
  }

  // 点击模块链接时更新激活状态
  document.querySelectorAll('.cheatsheet-module-link').forEach(link => {
    link.addEventListener('click', () => {
      requestAnimationFrame(updateActiveModule)
    })
  })

  // 监听 hash 变化
  window.addEventListener('hashchange', updateActiveModule)

  // 初始化激活状态
  updateActiveModule()
</script>
