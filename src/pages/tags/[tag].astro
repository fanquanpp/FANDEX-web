---
import Layout from '@/components/Layout.astro';
import SEO from '@/components/SEO.astro';
import Breadcrumb from '@/components/Breadcrumb.astro';
import GeoBgDecor from '@/components/GeoBgDecor.astro';
// 通过 tag-service 获取标签数据，UI 层禁止直接调用 getCollection
import { getAllTags, getDocsByTag, docSlug, type DocEntry } from '@/services';
import { getModule, categoryColors, getPrimaryCategory } from '@/lib/modules';

export async function getStaticPaths() {
  // 通过 tag-service 获取所有标签（含文档数量），生成静态路径
  const allTags = await getAllTags();
  return allTags.map(({ tag }) => ({
    params: { tag },
    props: { tag },
  }));
}

const { tag } = Astro.props as { tag: string };
// 通过 tag-service 获取包含该标签的文档（已按 order 升序排序）
const sortedDocs: DocEntry[] = await getDocsByTag(tag);
const base = import.meta.env.BASE_URL;

// 按模块分组文档
const moduleGroups = new Map<string, DocEntry[]>();
for (const doc of sortedDocs) {
  const mod = doc.data.module;
  if (!moduleGroups.has(mod)) moduleGroups.set(mod, []);
  moduleGroups.get(mod)!.push(doc);
}

const breadcrumb = [
  { label: '首页', href: `${base}` },
  { label: '标签', href: `${base}tags/` },
  { label: tag },
];
---

<Layout title={`标签: ${tag}`}>
  <SEO slot="head" title={`标签: ${tag}`} description={`包含标签 "${tag}" 的所有文档`} />

  <div class="tag-page">
    <!-- 几何背景装饰层 · list 变体：列表页装饰 -->
    <GeoBgDecor variant="list" />
    <Breadcrumb items={breadcrumb} />

    <div class="tag-header">
      <h1 class="tag-title">{tag}</h1>
      <p class="tag-subtitle">{sortedDocs.length} 篇文档 | {moduleGroups.size} 个模块</p>
    </div>

    <div class="tag-groups">
      {
        Array.from(moduleGroups.entries()).map(([mod, modDocs]) => {
          const meta = getModule(mod);
          return (
            <section class="tag-group">
              <h2 class="tag-group-title">
                <span
                  class="group-bar"
                  style={`background:${meta ? categoryColors[getPrimaryCategory(meta)] : categoryColors.toolchain}`}
                />
                <a href={`${base}${mod}/`} class="group-link">
                  {meta?.title || mod}
                </a>
                <span class="group-count">{modDocs.length}</span>
              </h2>
              <ul class="tag-doc-list">
                {modDocs.map((doc) => (
                  <li>
                    <a href={`${base}${mod}/${docSlug(doc.id)}/`} class="tag-doc-link">
                      {doc.data.title}
                    </a>
                  </li>
                ))}
              </ul>
            </section>
          );
        })
      }
    </div>
  </div>
</Layout>

<style>
  .tag-page {
    position: relative;
    padding: var(--spacing-lg) var(--spacing-xl);
    max-width: var(--content-width);
    margin: 0 auto;
  }

  /* 确保内容层在几何装饰层之上 */
  .tag-page > * {
    position: relative;
    z-index: 1;
  }

  .tag-header {
    margin-bottom: var(--spacing-xl);
  }

  .tag-title {
    font-family: var(--font-display);
    font-size: 1.4em;
    margin: 0 0 var(--spacing-xs);
    text-transform: capitalize;
  }

  .tag-subtitle {
    font-size: 0.88em;
    color: var(--color-text-secondary);
    margin: 0;
  }

  .tag-groups {
    display: flex;
    flex-direction: column;
    gap: var(--spacing-lg);
  }

  .tag-group {
    border: 1px solid var(--color-border-light);
    background: var(--color-bg);
  }

  .tag-group-title {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    margin: 0;
    background: var(--color-bg-card);
    border-bottom: 1px solid var(--color-border-light);
    font-size: 0.9em;
    font-weight: 600;
  }

  .group-bar {
    width: 3px;
    height: 14px;
    flex-shrink: 0;
  }

  .group-link {
    color: var(--color-text);
    text-decoration: none;
  }

  .group-link:hover {
    color: var(--color-primary);
  }

  .group-count {
    font-size: 0.8em;
    color: var(--color-text-tertiary);
    margin-left: auto;
  }

  .tag-doc-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .tag-doc-list li {
    border-bottom: 1px solid var(--color-border-light);
  }

  .tag-doc-list li:last-child {
    border-bottom: none;
  }

  .tag-doc-link {
    display: block;
    padding: var(--spacing-sm) var(--spacing-md);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.85em;
    transition: all var(--transition-fast);
  }

  .tag-doc-link:hover {
    background: var(--color-bg-hover);
    color: var(--color-primary);
    padding-left: calc(var(--spacing-md) + 8px);
  }

  @media (max-width: 768px) {
    .tag-page {
      padding: var(--spacing-md);
    }
  }
</style>
