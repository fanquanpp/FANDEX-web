---
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
import Sidebar from '@/components/Sidebar.astro'
import Breadcrumb from '@/components/Breadcrumb.astro'
import DocNav from '@/components/DocNav.astro'
import ProgressToggle from '@/islands/ProgressToggle.vue'
import QuizBlock from '@/islands/QuizBlock.vue'
import { getModule, modulePrerequisites } from '@/lib/modules'
import { getCollection } from 'astro:content'

export async function getStaticPaths() {
  const docs = await getCollection('docs')
  return docs.map(doc => {
    const slug = (doc.id.split('/').pop() || doc.id).replace(/\.md$/, '')
    return {
      params: { module: doc.data.module, slug },
      props: { doc },
    }
  })
}

const { doc } = Astro.props as any
const { module, slug } = Astro.params as { module: string; slug: string }
const { Content, headings } = await doc.render()
const meta = getModule(module || '')

function computeReadingTime(body: string, readingTime?: number): number {
  if (readingTime && readingTime > 0) return readingTime
  const stripped = body.replace(/```[\s\S]*?```/g, '').replace(/[#*`~\[\]()>_\-!|]/g, '')
  const chars = stripped.replace(/\s/g, '').length
  return Math.max(1, Math.ceil(chars / 300))
}

const readingTime = computeReadingTime(doc.body || '', doc.data.readingTime)

const breadcrumb = [
  { label: '首页', href: `${import.meta.env.BASE_URL}` },
  { label: meta?.title || module, href: `${import.meta.env.BASE_URL}${module}` },
  { label: doc.data.title },
]
---

<Layout title={doc.data.title}>
  <SEO
    slot="head"
    title={doc.data.title}
    description={doc.data.description}
    canonical={`${Astro.site}${Astro.url.pathname}`}
  />
  <Sidebar slot="sidebar" moduleId={module} currentSlug={slug} headings={headings} />

  <div class="doc-page">
    <Breadcrumb items={breadcrumb} />
    {(() => {
      const prereqs = doc.data.prerequisites?.length > 0
        ? doc.data.prerequisites
        : (modulePrerequisites[module] || [])
      if (prereqs.length === 0) return null
      return (
        <div class="prereq-notice">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
          <span>前置知识: {prereqs.map((p: string, i: number) => {
            const parts = p.split('/')
            const modId = parts[0]
            const modMeta = getModule(modId)
            const label = modMeta ? modMeta.title : p
            const href = parts.length > 1 ? `${import.meta.env.BASE_URL}${p}` : `${import.meta.env.BASE_URL}${modId}`
            return (<>{i > 0 && '、'}<a href={href}>{label}</a></>)
          })}</span>
        </div>
      )
    })()}
    <article class="prose"
      data-pagefind-body
      data-pagefind-filter={`difficulty:${doc.data.difficulty || 'intermediate'}, module:${module}${doc.data.category ? ', category:' + doc.data.category : ''}`}
    >
      <div class="doc-title-row">
        <h1 class="doc-title">{doc.data.title}</h1>
        <ProgressToggle client:load slug={`${module}/${slug}`} />
      </div>
      <header class="doc-header">
        <div class="doc-meta">
          <span class="doc-meta-item doc-reading-time">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
            {readingTime} min
          </span>
          <span class={`doc-meta-item doc-difficulty diff-${doc.data.difficulty || 'intermediate'}`}>
            {doc.data.difficulty === 'beginner' ? 'Beginner' : doc.data.difficulty === 'advanced' ? 'Advanced' : 'Intermediate'}
          </span>
          {doc.data.updated && (
            <span class="doc-meta-item doc-updated">
              <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="3" y="4" width="18" height="18" rx="2"/><line x1="16" y1="2" x2="16" y2="6"/><line x1="8" y1="2" x2="8" y2="6"/><line x1="3" y1="10" x2="21" y2="10"/></svg>
              {new Date(doc.data.updated).toLocaleDateString('zh-CN')}
            </span>
          )}
        </div>
        {doc.data.tags && doc.data.tags.length > 0 && (
          <div class="doc-tags">
            {doc.data.tags.map((tag: string) => (
              <a href={`${import.meta.env.BASE_URL}tags/${tag}`} class="doc-tag">{tag}</a>
            ))}
          </div>
        )}
        {doc.data.description && (
          <p class="doc-description">{doc.data.description}</p>
        )}
      </header>
      <Content />
    </article>
    <QuizBlock client:visible quiz={doc.data.quiz || []} />
    <DocNav moduleId={module} currentSlug={slug} />
  </div>
</Layout>

<style>
.doc-page {
  padding: var(--spacing-md) var(--spacing-lg) var(--spacing-2xl);
}

.prereq-notice {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-md);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-left: 3px solid #f59e0b;
  font-size: 0.85em;
  color: var(--color-text-secondary);
}

.prereq-notice svg {
  flex-shrink: 0;
  color: #f59e0b;
}

.prereq-notice a {
  color: var(--color-primary);
  text-decoration: none;
}

.prereq-notice a:hover {
  text-decoration: underline;
}

.doc-header {
  margin-bottom: var(--spacing-lg);
  padding-bottom: var(--spacing-lg);
  border-bottom: 1px solid var(--color-border-light);
}

.doc-title-row {
  position: sticky;
  top: 0;
  z-index: 20;
  background: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) 0;
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: var(--spacing-sm);
}

.doc-header {
  margin-bottom: var(--spacing-xl);
}

.doc-title-row .doc-title {
  margin-bottom: 0;
}

.doc-title {
  margin-bottom: var(--spacing-sm);
  font-size: 1.6em;
  line-height: 1.3;
}

.doc-meta {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  flex-wrap: wrap;
  margin-bottom: var(--spacing-sm);
}

.doc-meta-item {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  font-family: var(--font-display);
  font-size: 0.78em;
  color: var(--color-text-tertiary);
}

.doc-difficulty {
  padding: 2px 8px;
  border-radius: 3px;
  font-weight: 500;
  letter-spacing: 0.02em;
}

.diff-beginner {
  background: #e8f5e9;
  color: #2e7d32;
}

.diff-intermediate {
  background: #fff3e0;
  color: #e65100;
}

.diff-advanced {
  background: #fce4ec;
  color: #c62828;
}

:root[data-theme="dark"] .diff-beginner {
  background: #1b3a1b;
  color: #81c784;
}

:root[data-theme="dark"] .diff-intermediate {
  background: #3e2723;
  color: #ffb74d;
}

:root[data-theme="dark"] .diff-advanced {
  background: #3b1010;
  color: #ef9a9a;
}

.doc-tags {
  display: flex;
  flex-wrap: wrap;
  gap: 6px;
  margin-top: var(--spacing-sm);
}

.doc-tag {
  display: inline-block;
  padding: 2px 10px;
  font-size: 0.72em;
  font-family: var(--font-display);
  color: var(--color-text-secondary);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  text-decoration: none;
  transition: all var(--transition-fast);
}

.doc-tag:hover {
  color: var(--color-primary);
  border-color: var(--color-primary);
  background: var(--color-bg-hover);
}

.doc-description {
  margin-top: var(--spacing-sm);
  font-size: 0.92em;
  color: var(--color-text-secondary);
  line-height: 1.6;
}

@media (max-width: 768px) {
  .doc-page {
    padding: var(--spacing-sm) var(--spacing-md) var(--spacing-2xl);
  }

  .doc-title {
    font-size: 1.3em;
  }

  .doc-meta {
    gap: 6px;
  }
}
</style>
