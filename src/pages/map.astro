---
/**
 * 全局知识地图页
 * 通过 knowledge-map-service 在服务端构建全局 KnowledgeMap 数据，
 * 传递给 KnowledgeMap Vue 岛屿组件，由客户端渲染 Mermaid 图
 *
 * 数据流：
 * - 服务端：getGlobalMap() → 包含所有模块节点、模块间前置依赖、文档节点与文档间关联
 * - 客户端：KnowledgeMap.vue 接收 map 数据，渲染 Mermaid + 缩放/拖拽/节点点击跳转
 *
 * 使用场景：
 * - 站点级知识结构概览
 * - 跨模块学习路径探索
 */
import HomeLayout from '@/components/HomeLayout.astro';
import SEO from '@/components/SEO.astro';
import KnowledgeMap from '@/islands/KnowledgeMap.vue';
// 通过 services 桶文件统一导入：UI 层禁止直接调用 services 内部模块
import { getGlobalMap, getAllModules, toMermaidGraph } from '@/services';
import type { KnowledgeMap as KnowledgeMapData } from '@/services';

// 通过 knowledge-map-service 在服务端构建全局知识地图数据
const mapData: KnowledgeMapData = await getGlobalMap();
// 服务端预生成 Mermaid 语法字符串，避免客户端岛屿导入 astro:content
const graphSource: string = toMermaidGraph(mapData);

// 通过 module-service 获取全部模块（用于统计展示）
const allModules = getAllModules();

const base = import.meta.env.BASE_URL;
---

<HomeLayout title="全局知识地图">
  <SEO
    slot="head"
    title="全局知识地图"
    description="FANDEX 全站知识结构与学习路径地图，覆盖所有模块与文档的前置依赖与关联关系"
    type="website"
  />

  <div class="global-map-page">
    <section class="map-hero">
      <div class="map-hero-badge">Knowledge Map</div>
      <h1 class="map-hero-title">全局知识地图</h1>
      <p class="map-hero-desc">从模块依赖到文档关联，一张图看清 FANDEX 的知识结构</p>
      <div class="map-hero-stats">
        <div class="map-stat">
          <span class="map-stat-num">{allModules.length}</span>
          <span class="map-stat-label">模块</span>
        </div>
        <div class="map-stat-divider"></div>
        <div class="map-stat">
          <span class="map-stat-num">{mapData.nodes.length}</span>
          <span class="map-stat-label">节点</span>
        </div>
        <div class="map-stat-divider"></div>
        <div class="map-stat">
          <span class="map-stat-num">{mapData.edges.length}</span>
          <span class="map-stat-label">关系</span>
        </div>
      </div>
    </section>

    <!-- 知识地图渲染区：客户端水合 Mermaid 图，支持缩放/拖拽/节点点击跳转 -->
    <div class="map-render-area">
      <KnowledgeMap
        client:load
        scope="global"
        map={mapData}
        graphSource={graphSource}
        baseUrl={base}
      />
    </div>

    <!-- 模块快速跳转：作为图视图的可访问性补充，便于键盘/屏幕阅读器用户跳转 -->
    <section class="map-modules-section" aria-label="模块快速跳转">
      <h2 class="map-modules-title">模块快速跳转</h2>
      <div class="map-modules-grid">
        {
          allModules.map((mod) => (
            <a href={`${base}${mod.id}/map/`} class="map-module-card">
              <span class="map-module-id">{mod.id}</span>
              <span class="map-module-title">{mod.title}</span>
            </a>
          ))
        }
      </div>
    </section>
  </div>
</HomeLayout>

<style>
  .global-map-page {
    padding: var(--spacing-xl) var(--spacing-lg) var(--spacing-2xl);
    max-width: 1400px;
    margin: 0 auto;
  }

  .map-hero {
    text-align: center;
    margin-bottom: var(--spacing-xl);
  }

  .map-hero-badge {
    display: inline-block;
    padding: 4px 12px;
    font-size: 0.78em;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    margin-bottom: var(--spacing-md);
  }

  .map-hero-title {
    font-family: var(--font-display);
    font-size: 2em;
    margin: 0 0 var(--spacing-sm);
  }

  .map-hero-desc {
    font-size: 0.95em;
    color: var(--color-text-secondary);
    margin: 0 0 var(--spacing-lg);
  }

  .map-hero-stats {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) var(--spacing-lg);
    border: 1px solid var(--color-border-light);
    background: var(--color-bg-card);
  }

  .map-stat {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 2px;
  }

  .map-stat-num {
    font-family: var(--font-display);
    font-size: 1.4em;
    font-weight: 700;
    color: var(--color-text);
    font-variant-numeric: tabular-nums;
  }

  .map-stat-label {
    font-size: 0.75em;
    color: var(--color-text-secondary);
  }

  .map-stat-divider {
    width: 1px;
    height: 24px;
    background: var(--color-border);
  }

  .map-render-area {
    margin-bottom: var(--spacing-2xl);
  }

  .map-modules-section {
    margin-top: var(--spacing-2xl);
  }

  .map-modules-title {
    font-family: var(--font-display);
    font-size: 1.1em;
    font-weight: 700;
    margin: 0 0 var(--spacing-md);
    padding-bottom: var(--spacing-sm);
    border-bottom: 1px solid var(--color-border-light);
  }

  .map-modules-grid {
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
    gap: 1px;
    background: var(--color-border-light);
    border: 1px solid var(--color-border-light);
  }

  .map-module-card {
    display: flex;
    flex-direction: column;
    gap: 4px;
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-bg);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .map-module-card:hover {
    background: var(--color-bg-hover);
  }

  .map-module-id {
    font-family: var(--font-mono, monospace);
    font-size: 0.72em;
    color: var(--color-text-tertiary);
    text-transform: lowercase;
  }

  .map-module-title {
    font-size: 0.88em;
    color: var(--color-text);
    font-weight: 500;
  }

  @media (max-width: 768px) {
    .global-map-page {
      padding: var(--spacing-md) var(--spacing-md) var(--spacing-2xl);
    }

    .map-hero-title {
      font-size: 1.5em;
    }

    .map-modules-grid {
      grid-template-columns: repeat(auto-fill, minmax(140px, 1fr));
    }
  }
</style>
