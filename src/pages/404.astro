---
import '@/styles/variables.css';
import '@/styles/global.css';
import '@/styles/typography.css';
import '@/styles/code.css';
import '@/styles/components.css';
import '@/styles/geo-decor.css';
import GeoBgDecor from '@/components/GeoBgDecor.astro';
import { modules, categoryColors, getPrimaryCategory } from '@/lib/modules';
import { SITE } from '@/lib/constants';
import { MINIMAL_CSP } from '@/lib/csp';

const base = import.meta.env.BASE_URL;
const topModules = modules.slice(0, 6);
---

<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Security-Policy" content={MINIMAL_CSP} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />
    <title>404 - 页面未找到 | {SITE.title}</title>

    <link rel="stylesheet" href={`${base}fonts/fonts.css`} />
    <link
      rel="preload"
      href={`${base}fonts/jetbrains-mono-400.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={`${base}fonts/jetbrains-mono-700.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <script is:inline>
      (function () {
        var raw = localStorage.getItem('fandex-theme');
        var theme;
        if (raw === 'dark' || raw === 'light') {
          theme = raw;
        } else {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        // 始终显式设置 data-theme，避免 tokens.css 的 :root:not([data-theme])
        // 兜底逻辑在 prefers-color-scheme:dark 下覆盖用户已选择的 light
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
  </head>
  <body>
    <div class="error-page">
      <!-- 几何背景装饰层 · minimal 变体：克制装饰 -->
      <GeoBgDecor variant="minimal" />
      <div class="error-container">
        <div class="error-code">404</div>
        <h1 class="error-title">页面未找到</h1>
        <p class="error-desc">您访问的页面不存在或已被移动。请尝试搜索或浏览以下模块。</p>

        <div class="error-search">
          <!-- 404 页面搜索输入框：aria-label 提供可访问名，placeholder 不作为可访问名替代 -->
          <input
            type="text"
            id="error-search-input"
            placeholder="搜索模块..."
            class="error-search-input"
            aria-label="搜索模块"
          />
        </div>

        <div class="error-modules" id="error-modules">
          {
            topModules.map((m) => (
              <a href={`${base}${m.id}/`} class="error-module-card">
                <span
                  class="error-module-bar"
                  style={`background:${categoryColors[getPrimaryCategory(m)] || categoryColors.toolchain}`}
                />
                <span class="error-module-name">{m.title}</span>
                <span class="error-module-desc">{m.description}</span>
              </a>
            ))
          }
        </div>

        <a href={base} class="error-home-btn">
          <svg
            width="16"
            height="16"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
          >
            <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
            <polyline points="9 22 9 12 15 12 15 22"></polyline>
          </svg>
          返回首页
        </a>
      </div>
    </div>
  </body>
</html>

<script>
  const input = document.getElementById('error-search-input') as HTMLInputElement;
  const modulesEl = document.getElementById('error-modules');
  if (input && modulesEl) {
    const cards = modulesEl.querySelectorAll('.error-module-card');
    input.addEventListener('input', () => {
      const q = input.value.toLowerCase();
      cards.forEach((card) => {
        const name = card.querySelector('.error-module-name')?.textContent?.toLowerCase() || '';
        card.classList.toggle('hidden', q.length > 0 && !name.includes(q));
      });
    });
  }
</script>

<style>
  .error-page {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--spacing-lg);
    background: var(--color-bg);
  }

  /* 确保内容层在几何装饰层之上 */
  .error-container {
    position: relative;
    z-index: 1;
    max-width: 560px;
    width: 100%;
    text-align: center;
  }

  .error-code {
    font-family: var(--font-display);
    font-size: 6em;
    font-weight: 800;
    color: var(--color-primary);
    opacity: 0.2;
    line-height: 1;
    margin-bottom: var(--spacing-sm);
  }

  .error-title {
    font-family: var(--font-display);
    font-size: 1.4em;
    font-weight: 600;
    color: var(--color-text);
    margin: 0 0 var(--spacing-sm);
  }

  .error-desc {
    font-size: 0.9em;
    color: var(--color-text-secondary);
    margin: 0 0 var(--spacing-lg);
    line-height: 1.6;
  }

  .error-search {
    margin-bottom: var(--spacing-lg);
  }

  .error-search-input {
    width: 100%;
    max-width: 360px;
    padding: var(--spacing-sm) var(--spacing-md);
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text);
    font-size: 0.9em;
    font-family: inherit;
    outline: none;
    transition: border-color var(--transition-fast);
  }

  .error-search-input:focus {
    border-color: var(--color-primary);
  }

  .error-search-input::placeholder {
    color: var(--color-text-tertiary);
  }

  .error-modules {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
    background: var(--color-border-light);
    border: 1px solid var(--color-border-light);
    margin-bottom: var(--spacing-lg);
  }

  .error-module-card {
    display: flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-md);
    background: var(--color-bg);
    text-decoration: none;
    transition: background var(--transition-fast);
  }

  .error-module-card:hover {
    background: var(--color-bg-hover);
  }

  .error-module-card.hidden {
    display: none;
  }

  .error-module-bar {
    width: 3px;
    height: 16px;
    flex-shrink: 0;
  }

  .error-module-name {
    font-size: 0.82em;
    font-weight: 500;
    color: var(--color-text);
    flex: 1;
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .error-module-desc {
    font-size: 0.65em;
    color: var(--color-text-tertiary);
    flex-shrink: 0;
    display: none;
  }

  @media (min-width: 769px) {
    .error-module-desc {
      display: inline;
    }
  }

  .error-home-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-sm);
    padding: var(--spacing-sm) var(--spacing-lg);
    background: var(--color-text);
    color: var(--color-bg);
    text-decoration: none;
    font-size: 0.9em;
    font-weight: 500;
    transition: opacity var(--transition-fast);
  }

  .error-home-btn:hover {
    opacity: 0.85;
  }

  @media (max-width: 768px) {
    .error-modules {
      grid-template-columns: repeat(2, 1fr);
    }

    .error-code {
      font-size: 4em;
    }
  }
</style>
