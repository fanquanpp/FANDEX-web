---
import Layout from '@/components/Layout.astro'
import SEO from '@/components/SEO.astro'
import GeoBgDecor from '@/components/GeoBgDecor.astro'
import { modules } from '@/lib/modules'
---

<Layout title="搜索">
  <SEO slot="head" title="搜索 - FANDEX" description="全文搜索知识库" type="website" />
  <div class="search-page">
    <!-- 几何背景装饰层 · minimal 变体：克制装饰 -->
    <GeoBgDecor variant="minimal" />
    <h1 class="search-title">搜索</h1>
    <div class="search-filters">
      <select id="filter-module" class="search-filter-select">
        <option value="">全部模块</option>
        {modules.map(m => <option value={m.id}>{m.title}</option>)}
      </select>
      <select id="filter-difficulty" class="search-filter-select">
        <option value="">全部难度</option>
        <option value="beginner">Beginner</option>
        <option value="intermediate">Intermediate</option>
        <option value="advanced">Advanced</option>
      </select>
    </div>
    <div id="search" class="search-container"></div>
    <noscript>
      <p class="search-noscript">需要启用 JavaScript 才能使用搜索功能</p>
    </noscript>
  </div>
</Layout>

<style>
.search-page {
  position: relative;
  max-width: var(--content-width);
  margin: 0 auto;
  padding: var(--spacing-lg) var(--spacing-lg) var(--spacing-2xl);
}

/* 确保内容层在几何装饰层之上 */
.search-page > * {
  position: relative;
  z-index: 1;
}

.search-title {
  font-family: var(--font-display);
  font-size: 1.4em;
  margin-bottom: var(--spacing-lg);
}

.search-filters {
  display: flex;
  gap: var(--spacing-sm);
  margin-bottom: var(--spacing-md);
}

.search-filter-select {
  padding: 6px 10px;
  border: 1px solid var(--color-border);
  border-radius: 0;
  background: var(--color-bg-card);
  color: var(--color-text);
  font-family: var(--font-display);
  font-size: 0.85em;
  cursor: pointer;
  appearance: auto;
}

.search-container {
  min-height: 400px;
}

.search-noscript {
  color: var(--color-text-tertiary);
  text-align: center;
  padding: var(--spacing-2xl);
}

:global(.pagefind-ui) {
  --pagefind-ui-scale: 1;
  --pagefind-ui-primary: var(--color-primary);
  --pagefind-ui-text: var(--color-text);
  --pagefind-ui-background: var(--color-bg);
  --pagefind-ui-border: var(--color-border);
  --pagefind-ui-tag: var(--color-bg-card);
  --pagefind-ui-border-width: 1px;
  --pagefind-ui-border-radius: 4px;
  --pagefind-ui-image-border-radius: 4px;
  --pagefind-ui-image-box-ratio: 3 / 2;
  --pagefind-ui-font: var(--font-display);
}
</style>

<script>
  async function initPagefind() {
    const base = import.meta.env.BASE_URL
    const searchEl = document.getElementById('search')
    if (!searchEl) return

    if (import.meta.env.DEV) {
      searchEl.innerHTML = '<p style="color:var(--color-text-tertiary);text-align:center;padding:2em;">开发模式下未生成搜索索引，请运行 npm.cmd run build 后使用。</p>'
      return
    }

    try {
      const pagefind = (await import(/* @vite-ignore */ `${base}pagefind/pagefind.js`)) as PagefindModule
      await pagefind.options({ baseUrl: base, basePath: `${base}pagefind/` })
      await pagefind.init()

      const ui = new pagefind.UI({
        element: '#search',
        showSubResults: true,
        showImages: false,
      })

      const filterModule = document.getElementById('filter-module') as HTMLSelectElement
      const filterDifficulty = document.getElementById('filter-difficulty') as HTMLSelectElement

      function applyFilters() {
        const filters: Record<string, string> = {}
        if (filterModule?.value) filters.module = filterModule.value
        if (filterDifficulty?.value) filters.difficulty = filterDifficulty.value
        if (Object.keys(filters).length > 0) {
          ui.filter(filters)
        } else {
          ui.filter({})
        }
      }

      filterModule?.addEventListener('change', applyFilters)
      filterDifficulty?.addEventListener('change', applyFilters)

      const params = new URLSearchParams(window.location.search)
      const q = params.get('q')
      if (q) {
        ui.triggerSearch(q)
      }
    } catch (e) {
      searchEl.innerHTML = '<p style="color:var(--color-text-tertiary);text-align:center;padding:2em;">搜索索引尚未构建，请先运行 npm run build</p>'
    }
  }

  document.addEventListener('astro:page-load', initPagefind)
  initPagefind()
</script>
