---
/**
 * 首页
 * 展示所有学习模块，按分类分组显示
 * 包含 Hero 区域（统计信息）、分类模块网格、页脚
 */
import HomeLayout from '@/components/HomeLayout.astro'
import SEO from '@/components/SEO.astro'
import ModuleCard from '@/components/ModuleCard.astro'
import { modules, categoryLabels, categoryColors, getModulesByCategory, categoryOrder } from '@/lib/modules'
import { getCollection } from 'astro:content'

// 获取所有文档，统计各模块文档数量
const allDocs = await getCollection('docs')
const base = import.meta.env.BASE_URL
const docCountMap: Record<string, number> = {}
allDocs.forEach(doc => {
  const m = doc.data.module
  docCountMap[m] = (docCountMap[m] || 0) + 1
})

// 按分类顺序分组模块
const grouped = categoryOrder
  .map(cat => ({
    key: cat,
    label: categoryLabels[cat],
    color: categoryColors[cat],
    modules: getModulesByCategory(cat),
  }))
  .filter(g => g.modules.length > 0)

// 统计所有标签数量
const totalTags = new Set<string>()
allDocs.forEach(doc => {
  if (doc.data.tags) doc.data.tags.forEach((t: string) => totalTags.add(t))
})
---

<HomeLayout title="首页">
  <SEO slot="head" title="FANDEX" description="循序渐进的自学之旅，从第一行代码到理解整个世界。覆盖工具链、开发语言、数据库、计算机科学、工程基础设施与数据技术六大领域" type="website" />

  <div class="home-page">
    <!-- Hero 区域：站点标题和统计信息 -->
    <section class="hero">
      <div class="hero-badge">Zero to Mastery</div>
      <h1 class="hero-title"><span class="hero-title-fan">FAN</span>DEX</h1>
      <p class="hero-desc">循序渐进，从第一行代码到理解整个世界</p>
      <!-- 统计数据栏 -->
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-num">{modules.length}</span>
          <span class="stat-label">模块</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">{allDocs.length}</span>
          <span class="stat-label">文档</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">{totalTags.size}</span>
          <span class="stat-label">标签</span>
        </div>
        <div class="stat-divider"></div>
        <a href={`${import.meta.env.BASE_URL}roadmap/`} class="stat-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          学习路线
        </a>
        <div class="stat-divider"></div>
        <a href={`${import.meta.env.BASE_URL}tags/`} class="stat-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          标签索引
        </a>
        <div class="stat-divider"></div>
        <a href={`${import.meta.env.BASE_URL}cheatsheet/`} class="stat-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>
          语法速查
        </a>
      </div>
    </section>

    <!-- 按分类展示模块卡片 -->
    {grouped.map(group => (
      <section class="category-section" data-category={group.key}>
        <div class="category-header" data-toggle>
          <span class="category-tag" style={`color:${group.color}`}>{group.label}</span>
          <!-- 折叠/展开按钮 -->
          <button class="category-toggle" aria-label="折叠/展开" title="折叠/展开">
            <svg class="toggle-icon" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 9 12 15 18 9"/></svg>
          </button>
        </div>
        <!-- 模块卡片网格 -->
        <div class="feature-grid">
          {group.modules.map(mod => (
            <ModuleCard mod={mod} color={group.color} />
          ))}
        </div>
      </section>
    ))}

    <!-- 页脚 -->
    <footer class="home-footer">
      <div class="footer-links">
        <a href={`${base}getting-started/免责声明/`}>免责声明</a>
        <span class="footer-divider">|</span>
        <a href="https://github.com/fanquanpp/FANDEX" target="_blank" rel="noopener noreferrer">GitHub</a>
      </div>
      <div class="footer-stats">
        <span>{allDocs.length} 篇文档</span>
        <span class="footer-divider">·</span>
        <span>{modules.length} 个模块</span>
        <span class="footer-divider">·</span>
        <span>{totalTags.size} 个标签</span>
      </div>
      <div class="footer-tech">
        Built with Astro 5 SSG · Hosted on GitHub Pages
      </div>
      <div class="footer-notice">
        内容由人工与 AI 共同编撰，可能存在遗漏或错误，请结合官方资料独立验证
      </div>
      <div class="footer-notice">
        更新后构建约需 12 分钟，已访问页面需手动刷新方可显示最新版本
      </div>
    </footer>
  </div>
</HomeLayout>

<style>
/* 首页容器 */
.home-page {
  width: 100%;
  min-height: calc(100vh - var(--nav-height));
  min-height: calc(100dvh - var(--nav-height));
  margin: 0 auto;
  padding: 0 var(--spacing-lg) var(--spacing-2xl);
}

/* Hero 区域：居中展示 */
.hero {
  text-align: center;
  padding: var(--spacing-xl) 0 var(--spacing-xl);
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: var(--spacing-xl);
}

/* "Zero to Mastery" 徽章 */
.hero-badge {
  display: inline-block;
  font-family: var(--font-display);
  font-size: 0.65em;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  padding: 3px 14px;
  margin-bottom: var(--spacing-md);
}

/* 站点标题：FAN 部分使用主题色 */
.hero-title {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 800;
  letter-spacing: 0.25em;
  margin: 0 0 var(--spacing-sm);
  color: var(--color-text);
}

.hero-title-fan {
  color: var(--color-primary);
}

/* 站点描述 */
.hero-desc {
  font-size: 0.9rem;
  color: var(--color-text-secondary);
  margin: 0 0 var(--spacing-md);
  font-weight: 400;
  letter-spacing: 0.02em;
}

/* 统计数据栏 */
.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  font-family: var(--font-display);
  font-size: 0.82rem;
  flex-wrap: wrap;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding-bottom: 4px;
}

.stat-num {
  font-size: 1.3em;
  font-weight: 700;
  color: var(--color-text);
}

.stat-label {
  font-size: 0.78em;
  color: var(--color-text-secondary);
  letter-spacing: 0.04em;
}

/* 统计项之间的分隔线 */
.stat-divider {
  width: 1px;
  height: 24px;
  background: var(--color-border-light);
}

/* 快捷链接（学习路线、标签索引） */
.stat-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--color-primary);
  text-decoration: none;
  font-weight: 500;
  transition: opacity var(--transition-fast);
}

.stat-link:hover {
  opacity: 0.8;
}

/* 分类区域 */
.category-section {
  margin-bottom: var(--spacing-lg);
}

/* 分类标题栏：可点击折叠 */
.category-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-bottom: none;
  cursor: pointer;
  user-select: none;
}

/* 分类标签文字 */
.category-tag {
  font-family: var(--font-display);
  font-size: 0.85rem;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 0.05em;
}

.category-count {
  font-family: var(--font-display);
  font-size: 0.72rem;
  color: var(--color-text-tertiary);
}

/* 模块卡片网格：1px 间距形成分割线效果 */
.feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1px;
  background: var(--color-border-light);
  border: 1px solid var(--color-border-light);
  overflow: hidden;
}

.feature-grid.hidden {
  display: none;
}

/* 折叠/展开按钮 */
.category-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  padding: 4px;
  cursor: pointer;
  color: var(--color-text-tertiary);
  transition: color var(--transition-fast);
}

.category-toggle:hover {
  color: var(--color-text-secondary);
}

/* 折叠箭头旋转动画 */
.toggle-icon {
  transition: transform 0.2s ease;
}

.category-header.collapsed .toggle-icon {
  transform: rotate(-90deg);
}

/* 折叠状态下隐藏网格 */
.category-header.collapsed + .feature-grid {
  display: none;
}

/* 页脚 */
.home-footer {
  margin-top: var(--spacing-2xl);
  padding: var(--spacing-lg) 0;
  border-top: 1px solid var(--color-border-light);
  text-align: center;
  font-family: var(--font-display);
  font-size: 0.72em;
  color: var(--color-text-tertiary);
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.footer-links {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-sm);
}

.footer-links a {
  color: var(--color-text-secondary);
  text-decoration: none;
  transition: color var(--transition-fast);
}

.footer-links a:hover {
  color: var(--color-primary);
}

.footer-stats {
  color: var(--color-text-tertiary);
}

.footer-tech {
  color: var(--color-text-tertiary);
  opacity: 0.7;
}

.footer-notice {
  color: var(--color-text-tertiary);
  opacity: 0.5;
  font-size: 0.9em;
}

.footer-divider {
  opacity: 0.4;
}

/* 移动端适配（768px 以下） */
@media (max-width: 768px) {
  .home-page {
    padding: 0 var(--spacing-md) var(--spacing-2xl);
  }

  .hero-badge {
    font-size: 0.55em;
    padding: 2px 10px;
    margin-bottom: var(--spacing-xs);
  }

  .hero-title {
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    margin: 0;
  }

  .hero-stats {
    gap: var(--spacing-sm);
  }

  .stat-num {
    font-size: 1.1em;
  }

  .feature-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
  }

  .module-card {
    padding: var(--spacing-sm);
    gap: var(--spacing-xs);
  }

  .card-icon {
    width: 28px;
    height: 28px;
    font-size: 0.65rem;
  }

  .card-title {
    font-size: 0.82rem;
  }

  .card-desc {
    font-size: 0.72rem;
  }
}

/* 小屏幕适配（480px 以下） */
@media (max-width: 480px) {
  .feature-grid {
    grid-template-columns: repeat(3, 1fr);
    gap: 1px;
  }

  .module-card {
    padding: var(--spacing-xs);
    gap: 4px;
  }

  .card-icon {
    width: 24px;
    height: 24px;
    font-size: 0.6rem;
  }

  .card-title {
    font-size: 0.75rem;
  }

  .card-desc {
    font-size: 0.65rem;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  /* 小屏幕隐藏统计分隔线 */
  .stat-divider {
    display: none;
  }

  .hero-stats {
    gap: var(--spacing-md);
  }
}
</style>

<script>
// 分类区域折叠/展开
document.querySelectorAll('.category-header[data-toggle]').forEach(header => {
  header.addEventListener('click', () => {
    header.classList.toggle('collapsed')
  })
})
</script>
