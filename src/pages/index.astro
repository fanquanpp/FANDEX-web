---
import HomeLayout from '@/components/HomeLayout.astro'
import SEO from '@/components/SEO.astro'
import ModuleCard from '@/components/ModuleCard.astro'
import { modules, categoryLabels, getModulesByCategory, categoryOrder } from '@/lib/modules'
import { getCollection } from 'astro:content'

const allDocs = await getCollection('docs')
const base = import.meta.env.BASE_URL
const docCountMap: Record<string, number> = {}
allDocs.forEach(doc => {
  const m = doc.data.module
  docCountMap[m] = (docCountMap[m] || 0) + 1
})

const grouped = categoryOrder
  .map(cat => ({
    key: cat,
    label: categoryLabels[cat],
    modules: getModulesByCategory(cat),
  }))
  .filter(g => g.modules.length > 0)

const totalTags = new Set<string>()
allDocs.forEach(doc => {
  if (doc.data.tags) doc.data.tags.forEach((t: string) => totalTags.add(t))
})
---

<HomeLayout title="首页">
  <SEO slot="head" title="FANDEX - 开发者知识库" description="18个模块的技术学习笔记，覆盖前端/后端/基础/工具全栈知识体系" type="website" />

  <div class="home-page">
    <div class="hero-sticky" id="hero-sticky">
      <div class="hero-sticky-inner">
        <div class="hero-badge">KNOWLEDGE BASE</div>
        <h1 class="hero-title">FANDEX</h1>
      </div>
    </div>
    <div class="hero-sticky-spacer" id="hero-sticky-spacer"></div>
    <section class="hero">
      <div class="hero-search">
        <svg class="hero-search-icon" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        <input
          type="text"
          id="module-search"
          class="hero-search-input"
          placeholder="搜索模块名称或描述..."
          autocomplete="off"
        />
      </div>
      <div class="hero-stats">
        <div class="stat-item">
          <span class="stat-num">{modules.length}</span>
          <span class="stat-label">模块</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">{allDocs.length}</span>
          <span class="stat-label">文档</span>
        </div>
        <div class="stat-divider"></div>
        <div class="stat-item">
          <span class="stat-num">{totalTags.size}</span>
          <span class="stat-label">标签</span>
        </div>
        <div class="stat-divider"></div>
        <a href={`${import.meta.env.BASE_URL}roadmap/`} class="stat-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>
          学习路线
        </a>
        <div class="stat-divider"></div>
        <a href={`${import.meta.env.BASE_URL}tags/`} class="stat-link">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20.59 13.41l-7.17 7.17a2 2 0 0 1-2.83 0L2 12V2h10l8.59 8.59a2 2 0 0 1 0 2.82z"/><line x1="7" y1="7" x2="7.01" y2="7"/></svg>
          标签索引
        </a>
      </div>
    </section>

    <section class="category-section" data-category="basic-tools">
      <div class="category-header">
        <span class="category-tag">工具链</span>
      </div>
      <div class="feature-grid">
        <ModuleCard mod={modules.find(m => m.id === 'getting-started')!} color="#6366f1" />
        <ModuleCard mod={modules.find(m => m.id === 'markdown')!} color="#6366f1" />
        <ModuleCard mod={modules.find(m => m.id === 'git')!} color="#6366f1" />
        <ModuleCard mod={modules.find(m => m.id === 'github')!} color="#6366f1" />
      </div>
    </section>

    <section class="category-section" data-category="programming">
      <div class="category-header">
        <span class="category-tag">编程语言</span>
      </div>
      <div class="feature-grid">
        <ModuleCard mod={modules.find(m => m.id === 'c')!} color="#10b981" />
        <ModuleCard mod={modules.find(m => m.id === 'cpp')!} color="#10b981" />
        <ModuleCard mod={modules.find(m => m.id === 'java')!} color="#10b981" />
        <ModuleCard mod={modules.find(m => m.id === 'python')!} color="#10b981" />
        <ModuleCard mod={modules.find(m => m.id === 'javascript')!} color="#10b981" />
        <ModuleCard mod={modules.find(m => m.id === 'typescript')!} color="#10b981" />
        <ModuleCard mod={modules.find(m => m.id === 'lua')!} color="#10b981" />
      </div>
    </section>

    <section class="category-section" data-category="web-frontend">
      <div class="category-header">
        <span class="category-tag">前端工程</span>
      </div>
      <div class="feature-grid">
        <ModuleCard mod={modules.find(m => m.id === 'html5')!} color="#f59e0b" />
        <ModuleCard mod={modules.find(m => m.id === 'css')!} color="#f59e0b" />
        <ModuleCard mod={modules.find(m => m.id === 'javascript')!} color="#f59e0b" />
        <ModuleCard mod={modules.find(m => m.id === 'typescript')!} color="#f59e0b" />
        <ModuleCard mod={modules.find(m => m.id === 'vue3')!} color="#f59e0b" />
      </div>
    </section>

    <section class="category-section" data-category="data">
      <div class="category-header">
        <span class="category-tag">数据技术</span>
      </div>
      <div class="feature-grid">
        <ModuleCard mod={modules.find(m => m.id === 'python')!} color="#ef4444" />
        <ModuleCard mod={modules.find(m => m.id === 'mysql')!} color="#ef4444" />
        <ModuleCard mod={modules.find(m => m.id === 'data-analysis')!} color="#ef4444" />
      </div>
    </section>

    <section class="category-section" data-category="cs">
      <div class="category-header">
        <span class="category-tag">计算理论</span>
      </div>
      <div class="feature-grid">
        <ModuleCard mod={modules.find(m => m.id === 'algorithm')!} color="#8b5cf6" />
        <ModuleCard mod={modules.find(m => m.id === 'cs-fundamentals')!} color="#8b5cf6" />
      </div>
    </section>

    <footer class="home-footer">
      <p>Built with Astro 5 SSG | Hosted on GitHub Pages</p>
    </footer>
  </div>
</HomeLayout>

<style>
.home-page {
  max-width: 960px;
  margin: 0 auto;
  padding: 0 var(--spacing-lg) var(--spacing-2xl);
}

.hero-sticky {
  position: fixed;
  top: var(--nav-height);
  left: 0;
  right: 0;
  z-index: 50;
  background: var(--color-bg);
}

.hero-sticky-inner {
  max-width: 960px;
  margin: 0 auto;
  text-align: center;
  padding: var(--spacing-lg) 0 var(--spacing-md);
  position: relative;
}

.hero-sticky-inner::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 40%;
  height: 1px;
  background: var(--color-border-light);
}

.hero-sticky-spacer {
  height: 0;
}

.hero {
  text-align: center;
  padding: var(--spacing-lg) 0 var(--spacing-xl);
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: var(--spacing-xl);
}

.hero-badge {
  display: inline-block;
  font-family: var(--font-display);
  font-size: 0.65em;
  font-weight: 700;
  letter-spacing: 0.2em;
  color: var(--color-primary);
  border: 1px solid var(--color-primary);
  padding: 3px 14px;
  margin-bottom: var(--spacing-md);
}

.hero-title {
  font-family: var(--font-display);
  font-size: 3rem;
  font-weight: 800;
  letter-spacing: 0.25em;
  margin: 0 0 var(--spacing-sm);
  color: var(--color-text);
}

.hero-search {
  display: flex;
  align-items: center;
  max-width: 420px;
  margin: 0 auto var(--spacing-lg);
  border: 1px solid var(--color-border);
  background: var(--color-bg-card);
  transition: border-color var(--transition-fast);
}

.hero-search:focus-within {
  border-color: var(--color-primary);
}

.hero-search-icon {
  flex-shrink: 0;
  margin-left: var(--spacing-md);
  color: var(--color-text-tertiary);
}

.hero-search-input {
  flex: 1;
  padding: var(--spacing-sm) var(--spacing-md);
  border: none;
  background: transparent;
  color: var(--color-text);
  font-family: var(--font-display);
  font-size: 0.88em;
  outline: none;
}

.hero-search-input::placeholder {
  color: var(--color-text-tertiary);
}

.hero-stats {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: var(--spacing-md);
  font-family: var(--font-display);
  font-size: 0.82rem;
  flex-wrap: wrap;
}

.stat-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 4px;
  padding-bottom: 4px;
}

.stat-num {
  font-size: 1.3em;
  font-weight: 700;
  color: var(--color-text);
}

.stat-label {
  font-size: 0.78em;
  color: var(--color-text-secondary);
  letter-spacing: 0.04em;
}

.stat-divider {
  width: 1px;
  height: 24px;
  background: var(--color-border-light);
}

.stat-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--color-primary);
  text-decoration: none;
  font-weight: 500;
  transition: opacity var(--transition-fast);
}

.stat-link:hover {
  opacity: 0.8;
}

.category-section {
  margin-bottom: var(--spacing-lg);
}

.category-header {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  background: var(--color-bg-card);
  border: 1px solid var(--color-border-light);
  border-bottom: none;
}

.category-tag {
  font-family: var(--font-display);
  font-size: 0.72rem;
  font-weight: 700;
  color: var(--color-primary);
  letter-spacing: 0.05em;
}

.category-count {
  font-family: var(--font-display);
  font-size: 0.72rem;
  color: var(--color-text-tertiary);
}

.feature-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
  gap: 1px;
  background: var(--color-border-light);
  border: 1px solid var(--color-border-light);
}

.feature-grid.hidden {
  display: none;
}

.home-footer {
  margin-top: var(--spacing-2xl);
  padding-top: var(--spacing-lg);
  border-top: 1px solid var(--color-border-light);
  text-align: center;
  font-family: var(--font-display);
  font-size: 0.72em;
  color: var(--color-text-tertiary);
}

@media (max-width: 768px) {
  .home-page {
    padding: 0 var(--spacing-md) var(--spacing-2xl);
  }

  .hero-sticky-inner {
    padding: var(--spacing-sm) 0 var(--spacing-xs);
  }

  .hero-badge {
    font-size: 0.55em;
    padding: 2px 10px;
    margin-bottom: var(--spacing-xs);
  }

  .hero-title {
    font-size: 1.5rem;
    letter-spacing: 0.12em;
    margin: 0;
  }

  .hero-search {
    max-width: 100%;
  }

  .hero-stats {
    gap: var(--spacing-sm);
  }

  .stat-num {
    font-size: 1.1em;
  }

  .feature-grid {
    grid-template-columns: repeat(2, 1fr);
  }
}

@media (max-width: 480px) {
  .feature-grid {
    grid-template-columns: 1fr;
  }

  .stat-divider {
    display: none;
  }

  .hero-stats {
    gap: var(--spacing-md);
  }
}
</style>

<script>
  const heroSticky = document.getElementById('hero-sticky')
  const heroSpacer = document.getElementById('hero-sticky-spacer')
  if (heroSticky && heroSpacer) {
    const sync = () => {
      heroSpacer.style.height = heroSticky.offsetHeight + 'px'
    }
    sync()
    window.addEventListener('resize', sync)
  }

  const searchInput = document.getElementById('module-search') as HTMLInputElement | null
  if (searchInput) {
    searchInput.addEventListener('input', () => {
      const query = searchInput.value.trim().toLowerCase()
      const sections = document.querySelectorAll('.category-section')

      sections.forEach(section => {
        const cards = section.querySelectorAll('.module-card')
        let visibleCount = 0

        cards.forEach(card => {
          const title = card.querySelector('.card-title')?.textContent?.toLowerCase() || ''
          const desc = card.querySelector('.card-desc')?.textContent?.toLowerCase() || ''
          const matches = !query || title.includes(query) || desc.includes(query)
          ;(card as HTMLElement).style.display = matches ? '' : 'none'
          if (matches) visibleCount++
        })

        ;(section as HTMLElement).style.display = visibleCount > 0 ? '' : 'none'
      })
    })
  }
</script>
