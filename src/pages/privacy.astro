---
/**
 * 隐私政策页面
 * 说明 FANDEX 项目的数据存储方式、无跟踪无分析原则、第三方资源说明等
 * 使用 HomeLayout 布局，保持与全站一致的视觉风格
 */
import HomeLayout from '@/components/HomeLayout.astro';
import SEO from '@/components/SEO.astro';
import GeoBgDecor from '@/components/GeoBgDecor.astro';
import { SITE } from '@/lib/constants';

const base = import.meta.env.BASE_URL;
const currentYear = new Date().getFullYear();
---

<HomeLayout title="隐私政策">
  <SEO
    slot="head"
    title="隐私政策"
    description="FANDEX 项目隐私政策：数据存储方式、无跟踪无分析原则、本地存储说明、第三方资源说明等。"
    canonical={`${SITE.url}${base}privacy/`}
    type="website"
  />

  <div class="info-page">
    <!-- 几何背景装饰层 · docs 变体：克制装饰 -->
    <GeoBgDecor variant="docs" />

    <!-- 页面头部 -->
    <header class="info-header">
      <a href={base} class="back-home-btn">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2.5"><polyline points="18 6 6 12 18 18"></polyline></svg
        >
        返回首页
      </a>
      <h1 class="info-title">隐私政策</h1>
      <p class="info-subtitle">最后更新：2026 年 7 月</p>
    </header>

    <!-- 声明提示 -->
    <div class="notice-box">
      <strong
        >FANDEX
        尊重并保护每一位使用者的隐私。本政策详细说明本网站的数据处理方式。使用本网站即表示您已阅读并同意本隐私政策的全部条款。</strong
      >
    </div>

    <!-- 核心原则 -->
    <section class="info-section">
      <h2 class="section-title">一、核心原则</h2>
      <p class="section-text">
        FANDEX 是一个<strong>纯静态网站</strong>（Static Site
        Generation），所有页面在构建时预先生成为 HTML 文件，由 GitHub Pages
        托管。本网站不存在后端服务器，不收集、存储或传输任何使用者 personally identifiable
        information（个人可识别信息）。
      </p>
      <ul class="section-list">
        <li><strong>无注册登录</strong>：本网站不提供任何注册、登录功能，无需使用者提供账号信息</li>
        <li>
          <strong>无跟踪分析</strong>：本网站不使用 Google
          Analytics、百度统计或任何其他用户行为跟踪工具
        </li>
        <li><strong>无 Cookie</strong>：本网站不通过 Cookie 收集使用者信息</li>
        <li>
          <strong>无远程数据库</strong>：本网站不连接任何远程数据库，不将使用者数据发送至服务器
        </li>
      </ul>
    </section>

    <!-- 本地存储 -->
    <section class="info-section">
      <h2 class="section-title">二、本地存储说明</h2>
      <p class="section-text">
        为提供学习进度追踪、主题偏好记忆等功能，本网站在您的浏览器本地存储以下数据。这些数据<strong
          >仅存储在您的设备上</strong
        >，不会上传至任何服务器，您可以随时清除。
      </p>
      <div class="storage-table">
        <div class="storage-row storage-row-header">
          <span class="storage-cell">存储方式</span>
          <span class="storage-cell">键名</span>
          <span class="storage-cell">用途</span>
        </div>
        <div class="storage-row">
          <span class="storage-cell">localStorage</span>
          <span class="storage-cell">fandex-theme</span>
          <span class="storage-cell">记录用户的亮色/暗色主题偏好</span>
        </div>
        <div class="storage-row">
          <span class="storage-cell">localStorage</span>
          <span class="storage-cell">fandex-progress</span>
          <span class="storage-cell">记录用户已完成的文档列表</span>
        </div>
        <div class="storage-row">
          <span class="storage-cell">localStorage</span>
          <span class="storage-cell">fandex-fullscreen</span>
          <span class="storage-cell">记录用户的全屏模式偏好</span>
        </div>
        <div class="storage-row">
          <span class="storage-cell">IndexedDB</span>
          <span class="storage-cell">fandex-db</span>
          <span class="storage-cell">进度追踪数据的备份存储，防止 localStorage 清除后丢失</span>
        </div>
        <div class="storage-row">
          <span class="storage-cell">Cache Storage</span>
          <span class="storage-cell">sw-cache</span>
          <span class="storage-cell">Service Worker 缓存的静态资源，用于离线访问</span>
        </div>
      </div>
      <p class="section-text">
        以上所有数据均存储在您的浏览器本地，不会以任何形式发送至远程服务器。清除浏览器数据即可完全删除这些信息。
      </p>
    </section>

    <!-- Service Worker -->
    <section class="info-section">
      <h2 class="section-title">三、Service Worker 与离线访问</h2>
      <p class="section-text">
        本网站注册了 Service Worker 以提供离线访问能力。Service Worker
        会在您的浏览器中缓存网站的静态资源（HTML、CSS、JavaScript、字体、图片等），使您在无网络连接的情况下也能访问已缓存的页面。
      </p>
      <p class="section-text">
        Service Worker <strong>不会收集或传输您的个人信息</strong
        >。它仅拦截网络请求并返回缓存的静态资源，所有缓存数据存储在您的浏览器 Cache Storage 中。
      </p>
      <p class="section-text">
        如需清除 Service Worker 缓存，可通过浏览器开发者工具 -> Application -> Service Workers /
        Cache Storage 手动清除，或清除浏览器全部数据。
      </p>
    </section>

    <!-- 第三方资源 -->
    <section class="info-section">
      <h2 class="section-title">四、第三方资源</h2>
      <p class="section-text">
        本网站使用了以下第三方 CDN 资源，这些资源在加载时可能涉及与第三方服务器的连接：
      </p>
      <ul class="section-list">
        <li>
          <strong>jsDelivr CDN</strong>：用于加载 Mermaid
          图表库（知识地图功能），仅在访问知识地图页面时按需加载
        </li>
        <li>
          <strong>GitHub Pages</strong>：本网站托管于 GitHub Pages，GitHub 可能记录标准的 HTTP
          访问日志（IP 地址、访问时间、User-Agent 等），这些日志由 GitHub 管理，详见 <a
            href="https://docs.github.com/en/site-policy/privacy-policies/github-privacy-statement"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-link">GitHub 隐私声明</a
          >
        </li>
      </ul>
      <p class="section-text">除上述资源外，本网站不加载任何其他第三方脚本、像素标签或追踪器。</p>
    </section>

    <!-- 数据安全 -->
    <section class="info-section">
      <h2 class="section-title">五、数据安全</h2>
      <p class="section-text">
        由于本网站不在服务器端存储任何使用者数据，因此不存在服务器端数据泄露风险。所有本地存储的数据（学习进度、主题偏好等）均为非敏感信息，存储在您的浏览器中。
      </p>
      <p class="section-text">
        本网站配置了 <strong>Content Security Policy (CSP)</strong> 内容安全策略，限制脚本、样式、字体等资源的加载来源，防范跨站脚本攻击（XSS）等安全威胁。
      </p>
    </section>

    <!-- 儿童隐私 -->
    <section class="info-section">
      <h2 class="section-title">六、儿童隐私</h2>
      <p class="section-text">
        本网站面向所有年龄段的学习者开放，尤其鼓励零基础自学者使用。由于本网站不收集任何个人信息，因此不存在儿童隐私保护问题。监护人可放心让未成年人使用本网站进行学习。
      </p>
    </section>

    <!-- 政策变更 -->
    <section class="info-section">
      <h2 class="section-title">七、政策变更</h2>
      <p class="section-text">
        本仓库作者保留随时修改本隐私政策的权利。修改后的隐私政策自发布之日起生效，使用者应定期查阅以获取最新版本。继续使用本网站即视为接受修改后的条款。
      </p>
    </section>

    <!-- 联系方式 -->
    <section class="info-section">
      <h2 class="section-title">八、联系方式</h2>
      <p class="section-text">如您对本隐私政策有任何疑问或建议，欢迎通过以下方式联系：</p>
      <ul class="section-list">
        <li>
          GitHub Issues：<a
            href="https://github.com/fanquanpp/FANDEX-web/issues"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-link">fanquanpp/FANDEX-web</a
          >
        </li>
        <li>
          GitHub Discussions：<a
            href="https://github.com/fanquanpp/FANDEX-web/discussions"
            target="_blank"
            rel="noopener noreferrer"
            class="inline-link">参与讨论</a
          >
        </li>
      </ul>
    </section>

    <!-- 页脚 -->
    <footer class="info-footer">
      <div class="footer-links">
        <a href={`${base}about/`} class="footer-link">关于</a>
        <span class="footer-divider">|</span>
        <a href={`${base}disclaimer/`} class="footer-link">免责声明</a>
        <span class="footer-divider">|</span>
        <a
          href="https://github.com/fanquanpp/FANDEX-web"
          target="_blank"
          rel="noopener noreferrer"
          class="footer-link">GitHub</a
        >
      </div>
      <div class="footer-copyright">
        Copyright (c) 2024-{currentYear} fanquanpp · MIT License
      </div>
    </footer>
  </div>
</HomeLayout>

<style>
  /* 信息页容器：作为装饰层的定位上下文 */
  .info-page {
    position: relative;
    width: 100%;
    max-width: var(--content-width, 1280px);
    margin: 0 auto;
    padding: 0 var(--spacing-lg) var(--spacing-2xl);
    min-height: calc(100vh - var(--nav-height));
    min-height: calc(100dvh - var(--nav-height));
  }

  /* 确保内容层在几何装饰层之上 */
  .info-page > section,
  .info-page > header,
  .info-page > footer {
    position: relative;
    z-index: 1;
  }

  /* 返回首页按钮 */
  .back-home-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.8em;
    font-family: var(--font-display);
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .back-home-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* 页面头部 */
  .info-header {
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: var(--spacing-xl);
  }

  .info-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    margin: var(--spacing-sm) 0 var(--spacing-xs);
    color: var(--color-text);
  }

  .info-subtitle {
    font-size: 0.82rem;
    color: var(--color-text-tertiary);
    margin: 0;
    font-family: var(--font-display);
    letter-spacing: 0.02em;
  }

  /* 声明提示框 */
  .notice-box {
    position: relative;
    z-index: 1;
    padding: var(--spacing-md);
    margin-bottom: var(--spacing-xl);
    background: var(--color-bg-card);
    border: 1px solid var(--color-border-light);
    border-left: 3px solid var(--color-primary);
    font-size: 0.88rem;
    line-height: 1.7;
    color: var(--color-text-secondary);
  }

  /* 信息区块 */
  .info-section {
    margin-bottom: var(--spacing-xl);
  }

  .section-title {
    font-family: var(--font-display);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-text);
    margin: 0 0 var(--spacing-md);
    padding-left: var(--spacing-sm);
    border-left: 3px solid var(--color-primary);
  }

  .section-text {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    margin: 0 0 var(--spacing-sm);
  }

  .section-text strong {
    color: var(--color-text);
    font-weight: 600;
  }

  .section-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .section-list li {
    font-size: 0.88rem;
    line-height: 1.8;
    color: var(--color-text-secondary);
    padding: var(--spacing-xs) 0;
    padding-left: var(--spacing-md);
    position: relative;
  }

  .section-list li::before {
    content: '';
    position: absolute;
    left: 0;
    top: 0.85em;
    width: 6px;
    height: 6px;
    background: var(--color-primary);
    border-radius: 50%;
  }

  .section-list strong {
    color: var(--color-text);
    font-weight: 600;
  }

  /* 存储表格 */
  .storage-table {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--color-border-light);
    margin: var(--spacing-md) 0;
  }

  .storage-row {
    display: grid;
    grid-template-columns: 120px 160px 1fr;
    gap: var(--spacing-md);
    padding: var(--spacing-sm) var(--spacing-md);
    border-bottom: 1px solid var(--color-border-light);
  }

  .storage-row:last-child {
    border-bottom: none;
  }

  .storage-row-header {
    background: var(--color-bg-hover);
    font-family: var(--font-display);
    font-size: 0.75em;
    font-weight: 600;
    color: var(--color-text);
    letter-spacing: 0.02em;
  }

  .storage-cell {
    font-size: 0.82em;
    color: var(--color-text-secondary);
    line-height: 1.5;
  }

  .storage-cell:nth-child(2) {
    font-family: var(--font-mono, var(--font-display));
    font-size: 0.78em;
    color: var(--color-text);
  }

  /* 内联链接 */
  .inline-link {
    color: var(--color-primary);
    text-decoration: none;
    border-bottom: 1px dashed var(--color-primary);
  }

  .inline-link:hover {
    text-decoration: none;
    border-bottom-style: solid;
  }

  /* 页脚 */
  .info-footer {
    margin-top: var(--spacing-2xl);
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border-light);
    text-align: center;
  }

  .footer-links {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--spacing-sm);
    margin-bottom: var(--spacing-sm);
    flex-wrap: wrap;
  }

  .footer-link {
    font-family: var(--font-display);
    font-size: 0.78em;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--transition-fast);
  }

  .footer-link:hover {
    color: var(--color-primary);
  }

  .footer-divider {
    color: var(--color-text-tertiary);
    font-size: 0.78em;
  }

  .footer-copyright {
    font-family: var(--font-display);
    font-size: 0.72em;
    color: var(--color-text-tertiary);
    letter-spacing: 0.02em;
  }

  /* 移动端适配 */
  @media (max-width: 768px) {
    .info-page {
      padding: 0 var(--spacing-md) var(--spacing-2xl);
    }

    .info-title {
      font-size: 1.5rem;
    }

    .storage-row {
      grid-template-columns: 100px 1fr;
    }

    .storage-cell:nth-child(3) {
      grid-column: 1 / -1;
      padding-top: 2px;
    }

    .storage-row-header .storage-cell:nth-child(3) {
      display: none;
    }
  }
</style>
