---
/**
 * Design System Demo 页面
 *
 * 功能概述：
 * 作为 Phase 1.3 任务的成果展示页，集中展示 8 个基础 UI 组件的全部变体。
 * 通过 client:load 水合 DesignSystemDemo 岛屿组件，使所有 radix-vue 交互
 * 组件（Dialog、Tabs、Tooltip、Accordion 等）正常工作。
 *
 * 设计原则：
 * - 使用 HomeLayout 复用现有导航与主题切换按钮，验证双主题适配
 * - 单一岛屿组件统一管理交互状态，避免多次水合开销
 * - 页面本身保持薄壳结构，所有展示逻辑交给 Vue 组件
 */

import HomeLayout from '@/components/HomeLayout.astro';
import SEO from '@/components/SEO.astro';
import DesignSystemDemo from '@/islands/DesignSystemDemo.vue';
import { SITE } from '@/lib/constants';

const base = import.meta.env.BASE_URL;
---

<HomeLayout title="Design System">
  <SEO
    slot="head"
    title="设计系统 · FANDEX"
    description="FANDEX 设计系统展示页：8 个基础 UI 组件（Button、Card、Badge、Tooltip、Dialog、Tabs、Accordion、ScrollArea）的全变体演示，基于 Tailwind CSS v4 + shadcn-vue + radix-vue 实现。"
    canonical={`${SITE.url}${base}design-system/`}
    type="website"
  />

  <DesignSystemDemo client:load />
</HomeLayout>
