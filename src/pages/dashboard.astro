---
/**
 * 学习进度仪表盘页面
 *
 * 功能概述：
 * 展示用户在 FANDEX 中的学习进度数据，包括：
 * - 顶部 KPI 卡片：总文档、已完成、进行中、收藏、总阅读时长、连续打卡天数
 * - 习题作答统计：总习题数、已作答、答对数、正确率
 * - 各模块阅读进度条形图（基于 IndexedDB ProgressRecord 聚合）
 * - 最近阅读列表（5 条，从 IndexedDB 拉取）
 * - 错题集快速访问（链接到 dashboard/exercises）
 * - 推荐下一步学习（基于阅读历史与模块依赖）
 * - 数据管理：导出 / 导入 / 重置（合并阅读进度与习题进度）
 *
 * 技术实现：
 * - 使用 HomeLayout 布局保持与首页一致的视觉风格
 * - 通过 client:load 水合 ProgressDashboard Vue 组件
 * - 所有数据由客户端从 IndexedDB（主存储）+ localStorage（缓存）读取
 * - 双存储架构：sync localStorage + async IndexedDB
 * - 暗色模式适配（[data-theme='dark']）
 * - 支持 View Transitions（astro:page-load 事件）
 */
import HomeLayout from '@/components/HomeLayout.astro';
import SEO from '@/components/SEO.astro';
import GeoBgDecor from '@/components/GeoBgDecor.astro';
import ProgressDashboard from '@/islands/ProgressDashboard.vue';
import { SITE } from '@/lib/constants';

const base = import.meta.env.BASE_URL;
---

<HomeLayout title="学习进度">
  <SEO
    slot="head"
    title="学习进度 - FANDEX"
    description="查看你在 FANDEX 的学习进度：文档阅读统计、习题作答、最近阅读、错题集、连续打卡与个性化学习推荐。支持进度数据导出与导入。"
    canonical={`${SITE.url}${base}dashboard/`}
    type="website"
  />

  <div class="dashboard-page">
    <!-- 几何背景装饰层 · docs 变体：克制装饰 -->
    <GeoBgDecor variant="docs" />

    <!-- 页面头部 -->
    <header class="dashboard-header">
      <div class="header-top">
        <a href={base} class="back-home-btn">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2.5"><polyline points="18 6 6 12 18 18"></polyline></svg
          >
          返回首页
        </a>
        <a href={`${base}roadmap/`} class="roadmap-link-btn">
          <svg
            width="14"
            height="14"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"><path d="M3 6h18M3 12h18M3 18h18"></path></svg
          >
          学习路径
        </a>
      </div>
      <h1 class="dashboard-title">学习进度仪表盘</h1>
      <p class="dashboard-subtitle">追踪你的学习足迹，发现知识盲点，持续精进</p>
    </header>

    <!-- 进度仪表盘（Vue 岛屿组件） -->
    <ProgressDashboard client:load />

    <!-- 页脚 -->
    <footer class="dashboard-footer">
      <div class="footer-tip">
        <svg
          width="14"
          height="14"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <span
          >所有数据存储在本地浏览器，不会上传至服务器。清除浏览器数据将丢失进度，请定期导出备份。</span
        >
      </div>
    </footer>
  </div>
</HomeLayout>

<style>
  /* 仪表盘页面容器 */
  .dashboard-page {
    position: relative;
    width: 100%;
    min-height: calc(100vh - var(--nav-height));
    min-height: calc(100dvh - var(--nav-height));
    padding: 0 var(--spacing-lg) var(--spacing-2xl);
  }

  /* 确保内容层在几何装饰层之上 */
  .dashboard-page > header,
  .dashboard-page > footer {
    position: relative;
    z-index: 1;
  }

  /* 返回首页按钮 */
  .back-home-btn,
  .roadmap-link-btn {
    display: inline-flex;
    align-items: center;
    gap: var(--spacing-xs);
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    background: var(--color-bg-card);
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.8em;
    font-family: var(--font-display);
    transition:
      border-color var(--transition-fast),
      color var(--transition-fast);
  }

  .back-home-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  .roadmap-link-btn:hover {
    border-color: var(--color-primary);
    color: var(--color-primary);
  }

  /* 头部按钮行 */
  .header-top {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--spacing-sm);
  }

  /* 页面头部 */
  .dashboard-header {
    max-width: var(--content-width, 1280px);
    margin: 0 auto;
    padding: var(--spacing-xl) 0 var(--spacing-lg);
    border-bottom: 1px solid var(--color-border-light);
    margin-bottom: var(--spacing-lg);
  }

  .dashboard-title {
    font-family: var(--font-display);
    font-size: 2rem;
    font-weight: 800;
    letter-spacing: 0.15em;
    margin: var(--spacing-sm) 0 var(--spacing-xs);
    color: var(--color-text);
  }

  .dashboard-subtitle {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    margin: 0;
    letter-spacing: 0.02em;
  }

  /* 页脚提示 */
  .dashboard-footer {
    max-width: var(--content-width, 1280px);
    margin: var(--spacing-xl) auto 0;
    padding-top: var(--spacing-lg);
    border-top: 1px solid var(--color-border-light);
  }

  .footer-tip {
    display: flex;
    align-items: flex-start;
    gap: var(--spacing-sm);
    font-size: 0.78rem;
    color: var(--color-text-tertiary);
    line-height: 1.6;
  }

  .footer-tip svg {
    flex-shrink: 0;
    margin-top: 2px;
    color: var(--color-text-tertiary);
  }

  /* 移动端适配 */
  @media (max-width: 768px) {
    .dashboard-page {
      padding: 0 var(--spacing-md) var(--spacing-2xl);
    }

    .dashboard-title {
      font-size: 1.5rem;
    }
  }
</style>
