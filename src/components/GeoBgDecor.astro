---
/**
 * 几何背景装饰层通用组件
 *
 * 功能概述：
 * 根据视图变体渲染对应的构成主义几何装饰 div 组合。
 * 所有装饰层均设置 aria-hidden="true"，对辅助技术不可见。
 * 内部通过静态配置表 GEO_DECOR_CONFIG 维护各变体的装饰 div 列表，
 * 避免在各视图中重复书写冗长的装饰层标记。
 *
 * 适配来源：参考 KeMuONEXueKao 的 React 版 GeoBgDecor，重写为 Astro 组件。
 *
 * 变体说明：
 * - home：首页 Hero 区，品牌光晕 + S 曲线 + 涟漪环 + 三角切片等 10 项装饰
 * - docs：文档详情页，网格底纹 + 品牌光晕 + 几何线条 + 动态元素（克制 8 项）
 * - list：模块/标签列表页，网格底纹 + 平行斜线 + 十字坐标点 + 动态元素
 * - minimal：轻量变体，仅网格底纹 + 小点阵（搜索/404 等辅助页）
 */

/** 支持的视图变体类型 */
export type GeoBgVariant = 'home' | 'docs' | 'list' | 'minimal'

/** 装饰层单项：可仅为类名字符串，或携带内联 style 的对象（适配带定位的装饰元素） */
type GeoDecorItem = string | { readonly className: string; readonly style?: string }

/**
 * 各变体对应的装饰层 div 配置
 * - 数组顺序对应装饰 div 的书写顺序，保证视觉一致
 */
const GEO_DECOR_CONFIG: Record<GeoBgVariant, GeoDecorItem[]> = {
  /** 首页：品牌光晕 + S 曲线 + 涟漪环 + 三角切片等 10 项扩展装饰 */
  home: [
    'geo-glow-primary-tl',
    'geo-glow-accent-br',
    'geo-curve-s',
    'geo-ripple-tr',
    'geo-triangle-rt',
    'geo-cross-marks',
    'geo-spiral-ccw',
    'geo-pulse-ring',
    'geo-float-block',
    'geo-glow-info-bl'
  ],
  /** 文档详情页：网格底纹 + 品牌光晕 + 几何线条 + 动态元素
   *  克制使用 8 项装饰，营造专注但不单调的阅读氛围
   *  所有装饰均为低饱和度/低透明度，不干扰文字阅读 */
  docs: [
    'geo-bg-grid',
    'geo-glow-primary-tl',
    'geo-curve-s',
    'geo-cross-marks',
    'geo-dots-radial',
    'geo-bezier-flow',
    'geo-pulse-ring',
    'geo-float-block'
  ],
  /** 列表页：网格底纹 + 平行斜线 + 十字坐标点 + 多位置动态元素 */
  list: [
    'geo-bg-grid',
    'geo-parallel-lines',
    'geo-cross-marks',
    { className: 'geo-hatch-block', style: 'top:12%;right:4%' },
    'geo-dots-radial',
    'geo-chevron-stack',
    'geo-bezier-flow'
  ],
  /** 轻量变体：仅网格底纹 + 小点阵（搜索/404 等辅助页） */
  minimal: ['geo-bg-grid', 'geo-dots-sm']
}

interface Props {
  /** 视图变体，决定渲染哪些装饰层 */
  variant?: GeoBgVariant
}

/** 从 Props 解构 variant，默认 minimal 以保证未指定时的安全回退 */
const { variant = 'minimal' } = Astro.props
const items = GEO_DECOR_CONFIG[variant]
---

<div class="geo-bg-decor" aria-hidden="true">
  {
    items.map((item) => {
      const className = typeof item === 'string' ? item : item.className
      const style = typeof item === 'string' ? undefined : item.style
      return <div class={className} style={style} />
    })
  }
</div>
