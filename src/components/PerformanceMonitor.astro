---
/**
 * 性能监控面板组件 (PerformanceMonitor)
 *
 * 功能概述：
 * 仅在开发环境渲染的浮动性能监控面板，实时显示当前页面的 Web Vitals 指标
 * （LCP / INP / CLS / TTFB / FCP）与资源加载瀑布图（PerformanceObserver
 * Resource Timing），并在 bundle 超出预算时显示警告。
 *
 * 使用方式：
 *   import PerformanceMonitor from '@/components/PerformanceMonitor.astro';
 *   <PerformanceMonitor />  // 仅在 import.meta.env.DEV 时渲染
 *
 * 数据来源：
 * - 指标数据：通过 observability-service 从 localStorage 读取（WebVitalsTracker 采集）
 * - 资源瀑布：PerformanceObserver 监听 'resource' 类型条目，实时绘制
 * - Bundle 警告：构建期分析结果（开发期硬编码提示）
 *
 * 设计原则：
 * - 仅开发环境渲染，生产构建自动跳过（避免影响线上性能）
 * - 暗色模式适配：通过 CSS 变量跟随全局主题
 * - 不影响页面布局：position: fixed 浮动定位
 */

// 仅在开发环境渲染组件内容；生产环境直接返回空
const isDev = import.meta.env.DEV;
---

{isDev && (
  <aside id="fandex-perf-monitor" class="perf-monitor" aria-label="性能监控面板" role="complementary">
    <header class="perf-monitor-header">
      <span class="perf-monitor-title">性能监控</span>
      <div class="perf-monitor-actions">
        <button type="button" id="perf-monitor-toggle" aria-label="折叠/展开性能面板" title="折叠/展开">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <polyline points="6 9 12 15 18 9" />
          </svg>
        </button>
        <button type="button" id="perf-monitor-close" aria-label="关闭性能面板" title="关闭">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <line x1="18" y1="6" x2="6" y2="18" />
            <line x1="6" y1="6" x2="18" y2="18" />
          </svg>
        </button>
      </div>
    </header>

    <div id="perf-monitor-body" class="perf-monitor-body">
      <!-- Web Vitals 指标卡片区域 -->
      <section class="perf-section">
        <h3 class="perf-section-title">Web Vitals（当前页）</h3>
        <div class="perf-vitals-grid" id="perf-vitals-grid">
          <!-- JS 动态填充 -->
        </div>
      </section>

      <!-- 分位数汇总区域 -->
      <section class="perf-section">
        <h3 class="perf-section-title">汇总（p50 / p75 / p95）</h3>
        <div class="perf-summary" id="perf-summary">
          <!-- JS 动态填充 -->
        </div>
      </section>

      <!-- 资源加载瀑布图 -->
      <section class="perf-section">
        <h3 class="perf-section-title">资源瀑布（最近 20 项）</h3>
        <div class="perf-waterfall" id="perf-waterfall">
          <!-- JS 动态填充 -->
        </div>
      </section>

      <!-- Bundle 大小警告 -->
      <section class="perf-section">
        <h3 class="perf-section-title">Bundle 预算提示</h3>
        <div class="perf-bundle-warn" id="perf-bundle-warn">
          <p class="perf-hint">JS &gt; 150KB gzip / CSS &gt; 30KB gzip 视为超预算，详见 <code>reports/bundle-stats.html</code></p>
        </div>
      </section>

      <!-- 操作按钮 -->
      <section class="perf-section perf-actions">
        <button type="button" id="perf-export" class="perf-btn">导出 JSON</button>
        <button type="button" id="perf-clear" class="perf-btn perf-btn-danger">清空记录</button>
      </section>
    </div>
  </aside>
)}

<style>
/* 性能监控面板：固定右下角浮动卡片 */
.perf-monitor {
  position: fixed;
  right: 16px;
  bottom: 16px;
  width: 360px;
  max-height: 70vh;
  display: flex;
  flex-direction: column;
  background: var(--color-bg-card, #ffffff);
  border: 1px solid var(--color-border, #e5e7eb);
  border-radius: 8px;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  z-index: 9999;
  font-family: ui-monospace, 'JetBrains Mono', monospace;
  font-size: 12px;
  color: var(--color-text, #111827);
  overflow: hidden;
}

/* 暗色模式适配：通过 data-theme 属性切换 */
:global(html[data-theme='dark']) .perf-monitor {
  background: #1f2937;
  color: #f9fafb;
  border-color: #374151;
  box-shadow: 0 8px 24px rgba(0, 0, 0, 0.4);
}

.perf-monitor-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 8px 12px;
  background: var(--color-primary, #3b82f6);
  color: #ffffff;
  cursor: default;
}

.perf-monitor-title {
  font-weight: 600;
  font-size: 13px;
}

.perf-monitor-actions {
  display: flex;
  gap: 4px;
}

.perf-monitor-actions button {
  display: inline-flex;
  align-items: center;
  justify-content: center;
  width: 22px;
  height: 22px;
  background: rgba(255, 255, 255, 0.15);
  border: none;
  border-radius: 4px;
  color: #ffffff;
  cursor: pointer;
  padding: 0;
}

.perf-monitor-actions button:hover {
  background: rgba(255, 255, 255, 0.3);
}

.perf-monitor-body {
  padding: 10px 12px;
  overflow-y: auto;
  flex: 1;
}

.perf-monitor.collapsed .perf-monitor-body {
  display: none;
}

.perf-section {
  margin-bottom: 12px;
}

.perf-section:last-child {
  margin-bottom: 0;
}

.perf-section-title {
  margin: 0 0 6px 0;
  font-size: 11px;
  font-weight: 600;
  color: var(--color-text-secondary, #6b7280);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

:global(html[data-theme='dark']) .perf-section-title {
  color: #9ca3af;
}

/* Web Vitals 指标卡片网格 */
.perf-vitals-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(100px, 1fr));
  gap: 6px;
}

.perf-vital-card {
  padding: 6px 8px;
  background: var(--color-bg-hover, rgba(0, 0, 0, 0.04));
  border-radius: 4px;
  border-left: 3px solid #6b7280;
}

.perf-vital-card.rating-good {
  border-left-color: #10b981;
}

.perf-vital-card.rating-needs-improvement {
  border-left-color: #f59e0b;
}

.perf-vital-card.rating-poor {
  border-left-color: #ef4444;
}

:global(html[data-theme='dark']) .perf-vital-card {
  background: rgba(255, 255, 255, 0.05);
}

.perf-vital-name {
  font-size: 10px;
  font-weight: 600;
  color: var(--color-text-secondary, #6b7280);
}

.perf-vital-value {
  font-size: 14px;
  font-weight: 700;
  color: var(--color-text, #111827);
}

:global(html[data-theme='dark']) .perf-vital-value {
  color: #f9fafb;
}

/* 汇总区域 */
.perf-summary {
  display: grid;
  grid-template-columns: auto 1fr;
  gap: 4px 12px;
  font-size: 11px;
}

.perf-summary-row {
  display: contents;
}

.perf-summary-label {
  font-weight: 600;
}

.perf-summary-values {
  color: var(--color-text-secondary, #6b7280);
}

:global(html[data-theme='dark']) .perf-summary-values {
  color: #9ca3af;
}

/* 资源瀑布图 */
.perf-waterfall {
  display: flex;
  flex-direction: column;
  gap: 2px;
  max-height: 200px;
  overflow-y: auto;
}

.perf-waterfall-item {
  display: grid;
  grid-template-columns: 120px 1fr 60px;
  gap: 6px;
  align-items: center;
  font-size: 10px;
}

.perf-waterfall-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.perf-waterfall-bar-container {
  position: relative;
  height: 8px;
  background: var(--color-bg-hover, rgba(0, 0, 0, 0.04));
  border-radius: 2px;
  overflow: hidden;
}

:global(html[data-theme='dark']) .perf-waterfall-bar-container {
  background: rgba(255, 255, 255, 0.05);
}

.perf-waterfall-bar {
  position: absolute;
  top: 0;
  height: 100%;
  background: var(--color-primary, #3b82f6);
  border-radius: 2px;
}

.perf-waterfall-duration {
  text-align: right;
  color: var(--color-text-secondary, #6b7280);
}

:global(html[data-theme='dark']) .perf-waterfall-duration {
  color: #9ca3af;
}

.perf-hint {
  margin: 0;
  font-size: 10px;
  color: var(--color-text-secondary, #6b7280);
  line-height: 1.4;
}

.perf-hint code {
  background: var(--color-bg-hover, rgba(0, 0, 0, 0.06));
  padding: 1px 4px;
  border-radius: 2px;
  font-size: 10px;
}

.perf-actions {
  display: flex;
  gap: 6px;
}

.perf-btn {
  flex: 1;
  padding: 5px 8px;
  background: var(--color-bg-hover, rgba(0, 0, 0, 0.04));
  border: 1px solid var(--color-border, #e5e7eb);
  border-radius: 4px;
  color: var(--color-text, #111827);
  font-size: 11px;
  cursor: pointer;
  font-family: inherit;
}

.perf-btn:hover {
  background: var(--color-bg-hover-strong, rgba(0, 0, 0, 0.08));
}

.perf-btn-danger {
  color: #ef4444;
  border-color: #ef4444;
}

.perf-btn-danger:hover {
  background: rgba(239, 68, 68, 0.1);
}

.perf-empty {
  font-size: 11px;
  color: var(--color-text-secondary, #6b7280);
  font-style: italic;
}

:global(html[data-theme='dark']) .perf-empty {
  color: #9ca3af;
}
</style>

<script>
  // ========== 性能监控面板客户端逻辑 ==========
  // 仅在开发环境执行；生产环境组件未渲染，此脚本不注入
  // 引入类型定义：避免使用 mod.VitalRecord 等命名空间形式（mod 为运行时变量，不可作为类型）
  import type { VitalRecord, VitalName, VitalPercentiles } from '@services/observability-service';

  /**
   * 清除 panel 上挂载的定时器
   * 用于页面切换、面板关闭、面板重新初始化前清理 setInterval，避免内存泄漏
   */
  function clearMonitorInterval(panel: HTMLElement): void {
    const existing = panel.dataset.intervalId;
    if (existing) {
      const id = Number(existing);
      if (!Number.isNaN(id)) window.clearInterval(id);
      delete panel.dataset.intervalId;
    }
  }

  function initPerformanceMonitor(): void {
    const panel = document.getElementById('fandex-perf-monitor');
    if (!panel) return;

    // 先清除可能存在的旧定时器（Astro View Transitions 切换页面后再次初始化时清理）
    clearMonitorInterval(panel);

    const toggleBtn = document.getElementById('perf-monitor-toggle');
    const closeBtn = document.getElementById('perf-monitor-close');
    const vitalsGrid = document.getElementById('perf-vitals-grid');
    const summaryEl = document.getElementById('perf-summary');
    const waterfallEl = document.getElementById('perf-waterfall');
    const exportBtn = document.getElementById('perf-export');
    const clearBtn = document.getElementById('perf-clear');

    // 折叠/展开
    if (toggleBtn) {
      toggleBtn.addEventListener('click', () => {
        panel.classList.toggle('collapsed');
      });
    }

    // 关闭面板：同时清理定时器避免后台空跑
    if (closeBtn) {
      closeBtn.addEventListener('click', () => {
        panel.style.display = 'none';
        clearMonitorInterval(panel);
      });
    }

    // 动态导入 Service 层（避免 SSR 阶段加载）
    type ObservabilityModule = typeof import('@services/observability-service');
    async function loadObservability(): Promise<ObservabilityModule | null> {
      try {
        const mod = await import('@services/observability-service');
        return mod;
      } catch {
        return null;
      }
    }

    // 格式化毫秒数值
    function formatMs(value: number): string {
      if (!value || value === 0) return '—';
      if (value < 10) return value.toFixed(1) + 'ms';
      return Math.round(value) + 'ms';
    }

    // 格式化 CLS（无量纲小数）
    function formatCls(value: number): string {
      if (!value || value === 0) return '—';
      return value.toFixed(3);
    }

    // 根据 rating 获取 CSS 类名
    function ratingClass(rating: string): string {
      if (rating === 'good') return 'rating-good';
      if (rating === 'needs-improvement') return 'rating-needs-improvement';
      return 'rating-poor';
    }

    /**
     * HTML 特殊字符转义：用于将不可信文本安全嵌入 innerHTML 模板
     * @param str - 待转义的原始字符串
     * @returns 转义后的安全字符串（& < > " ' 已转为 HTML 实体）
     */
    function escapeHtml(str: string): string {
      return str
        .replace(/&/g, '&amp;')
        .replace(/</g, '&lt;')
        .replace(/>/g, '&gt;')
        .replace(/"/g, '&quot;')
        .replace(/'/g, '&#39;');
    }

    // 渲染当前页面 Web Vitals
    async function renderVitals(): Promise<void> {
      if (!vitalsGrid) return;
      const mod = await loadObservability();
      if (!mod) return;
      try {
        const all = mod.getVitals(20);
        // 按指标名称分组取最新一条
        const latest = new Map<string, VitalRecord>();
        for (const v of all) {
          if (!latest.has(v.name)) latest.set(v.name, v);
        }
        const names: VitalName[] = ['LCP', 'INP', 'CLS', 'TTFB', 'FCP'];
        const html = names.map((name) => {
          const v = latest.get(name);
          const value = v ? (name === 'CLS' ? formatCls(v.value) : formatMs(v.value)) : '—';
          const rating = v ? v.rating : 'good';
          return `
            <div class="perf-vital-card ${ratingClass(rating)}">
              <div class="perf-vital-name">${name}</div>
              <div class="perf-vital-value">${value}</div>
            </div>
          `;
        }).join('');
        vitalsGrid.innerHTML = html;
      } catch {
        vitalsGrid.innerHTML = '<p class="perf-empty">读取失败</p>';
      }
    }

    // 渲染汇总统计
    async function renderSummary(): Promise<void> {
      if (!summaryEl) return;
      const mod = await loadObservability();
      if (!mod) return;
      try {
        const s = mod.getVitalsSummary();
        const rows: Array<{ label: string; p: VitalPercentiles; fmt: (v: number) => string }> = [
          { label: 'LCP', p: s.lcp, fmt: formatMs },
          { label: 'INP', p: s.inp, fmt: formatMs },
          { label: 'CLS', p: s.cls, fmt: formatCls },
          { label: 'TTFB', p: s.ttfb, fmt: formatMs },
          { label: 'FCP', p: s.fcp, fmt: formatMs },
        ];
        const html = rows.map((r) => `
          <div class="perf-summary-row">
            <span class="perf-summary-label">${r.label}</span>
            <span class="perf-summary-values">p50 ${r.fmt(r.p.p50)} · p75 ${r.fmt(r.p.p75)} · p95 ${r.fmt(r.p.p95)}</span>
          </div>
        `).join('');
        summaryEl.innerHTML = html;
      } catch {
        summaryEl.innerHTML = '<p class="perf-empty">读取失败</p>';
      }
    }

    // 资源瀑布图：通过 performance.getEntriesByType 读取资源加载记录
    // 数据来源为浏览器 Performance API，e.name 为资源 URL，经 escapeHtml 转义后嵌入 HTML 属性与文本
    function renderWaterfall(): void {
      if (!waterfallEl) return;
      try {
        const entries = performance.getEntriesByType('resource') as PerformanceResourceTiming[];
        // 取最近 20 项，按 startTime 排序
        const recent = entries.slice(-20).sort((a, b) => a.startTime - b.startTime);
        if (recent.length === 0) {
          waterfallEl.innerHTML = '<p class="perf-empty">暂无资源加载记录</p>';
          return;
        }
        const maxEnd = Math.max(...recent.map((e) => e.responseEnd));
        const minStart = Math.min(...recent.map((e) => e.startTime));
        const totalSpan = Math.max(maxEnd - minStart, 1);
        const html = recent.map((e) => {
          // 资源 URL 转义后用于 title 属性与显示文本，防止 URL 中特殊字符触发 XSS
          const safeName = escapeHtml(e.name.split('/').pop() || e.name);
          const safeTitle = escapeHtml(e.name);
          const left = ((e.startTime - minStart) / totalSpan) * 100;
          const width = Math.max((e.duration / totalSpan) * 100, 2);
          const duration = e.duration < 10 ? e.duration.toFixed(1) + 'ms' : Math.round(e.duration) + 'ms';
          return `
            <div class="perf-waterfall-item">
              <span class="perf-waterfall-name" title="${safeTitle}">${safeName}</span>
              <div class="perf-waterfall-bar-container">
                <div class="perf-waterfall-bar" style="left:${left}%;width:${width}%"></div>
              </div>
              <span class="perf-waterfall-duration">${duration}</span>
            </div>
          `;
        }).join('');
        waterfallEl.innerHTML = html;
      } catch {
        waterfallEl.innerHTML = '<p class="perf-empty">读取失败</p>';
      }
    }

    // 导出 JSON
    if (exportBtn) {
      exportBtn.addEventListener('click', async () => {
        const mod = await loadObservability();
        if (!mod) return;
        try {
          const json = mod.exportVitalsJSON();
          const blob = new Blob([json], { type: 'application/json' });
          const url = URL.createObjectURL(blob);
          const a = document.createElement('a');
          a.href = url;
          a.download = 'fandex-web-vitals.json';
          a.click();
          URL.revokeObjectURL(url);
        } catch {
          // 异常时静默忽略
        }
      });
    }

    // 清空记录
    if (clearBtn) {
      clearBtn.addEventListener('click', async () => {
        const mod = await loadObservability();
        if (!mod) return;
        try {
          mod.clearVitals();
          await renderVitals();
          await renderSummary();
        } catch {
          // 异常时静默忽略
        }
      });
    }

    // 初次渲染
    renderVitals();
    renderSummary();
    renderWaterfall();

    // 定时刷新（每 2 秒）：将 intervalId 存入 dataset 便于页面切换/面板关闭时清理
    const intervalId = window.setInterval(() => {
      renderVitals();
      renderSummary();
      renderWaterfall();
    }, 2000);
    panel.dataset.intervalId = String(intervalId);
  }

  // Astro View Transitions 兼容：页面切换前清理旧定时器，避免累积内存泄漏
  document.addEventListener('astro:before-swap', () => {
    const panel = document.getElementById('fandex-perf-monitor');
    if (panel) clearMonitorInterval(panel);
  });
  // 页面切换后重新初始化
  document.addEventListener('astro:page-load', initPerformanceMonitor);
  initPerformanceMonitor();
</script>
