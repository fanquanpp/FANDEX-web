---
/**
 * SEO 组件
 * 生成页面的 SEO 元数据，包括标题、描述、Open Graph、Twitter Card 和结构化数据
 * 支持文章类型和网站类型两种结构化数据格式
 */
import { SITE } from '@/lib/constants';

const { title, description, canonical, type = 'article' } = Astro.props;
const fullTitle = `${title} | ${SITE.title}`;
const pageUrl = canonical || SITE.url;
const pageDescription = description || SITE.subtitle;

// 根据页面类型生成不同的 JSON-LD 结构化数据
const ldJson =
  type === 'article'
    ? {
        '@context': 'https://schema.org',
        '@type': 'Article',
        headline: title,
        description: pageDescription,
        url: pageUrl,
        author: {
          '@type': 'Person',
          name: SITE.author,
        },
        publisher: {
          '@type': 'Organization',
          name: SITE.title,
        },
      }
    : {
        '@context': 'https://schema.org',
        '@type': 'WebSite',
        name: SITE.title,
        url: SITE.url,
        description: SITE.subtitle,
      };
---

<title>{fullTitle}</title>
<meta name="description" content={pageDescription} />
<!-- Open Graph 元数据 -->
<meta property="og:title" content={fullTitle} />
<meta property="og:description" content={pageDescription} />
<meta property="og:type" content={type} />
<meta property="og:url" content={pageUrl} />
<!-- Twitter Card 元数据 -->
<meta name="twitter:card" content="summary_large_image" />
<!-- 规范链接 -->
<link rel="canonical" href={pageUrl} />
<!-- 结构化数据（JSON-LD） -->
<script type="application/ld+json" set:html={JSON.stringify(ldJson)} />
