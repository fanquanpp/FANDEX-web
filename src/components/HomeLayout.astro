---
/**
 * 首页布局组件
 * 提供首页的整体结构：顶部导航栏和主内容区
 * 导航栏包含免责声明链接、GitHub 仓库链接、全屏按钮和主题切换
 * 继承 BaseLayout 的共享 head 与样式引入，仅保留首页特有的结构与脚本
 */
import BaseLayout from '@/components/BaseLayout.astro';
import ThemeToggle from '@/islands/ThemeToggle.vue';
import { SITE } from '@/lib/constants';

const { title } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<BaseLayout title={title}>
  <slot name="head" slot="head" />

  <!-- 首页顶部导航栏 -->
  <header class="home-nav">
    <div class="nav-left">
      <a href={base} class="nav-logo">
        <span class="logo-mark"></span>
        <span class="logo-text">{SITE.title}<span class="logo-home-suffix">-Index</span></span>
      </a>
    </div>
    <div class="nav-right">
      <!-- 桌面端下载链接（FANDEX-exe） -->
      <a
        href="https://github.com/fanquanpp/FANDEX-exe/releases"
        class="nav-action-link"
        target="_blank"
        rel="noopener noreferrer"
        title="Windows 桌面端下载"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <rect x="2" y="3" width="20" height="14" rx="2" ry="2"></rect>
          <line x1="8" y1="21" x2="16" y2="21"></line>
          <line x1="12" y1="17" x2="12" y2="21"></line>
        </svg>
        <span class="nav-action-text">桌面端</span>
      </a>
      <!-- APP 下载链接（FANDEX-App） -->
      <a
        href="https://fanquanpp.github.io/FANDEX-App/"
        class="nav-action-link"
        target="_blank"
        rel="noopener noreferrer"
        title="Android APP 下载"
      >
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"></path>
          <polyline points="7 10 12 15 17 10"></polyline>
          <line x1="12" y1="15" x2="12" y2="3"></line>
        </svg>
        <span class="nav-action-text">APP 下载</span>
      </a>
      <!-- 关于链接：指向站内关于页面 -->
      <a href={`${base}about/`} class="nav-action-link" title="关于">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="12" cy="12" r="10"></circle>
          <line x1="12" y1="16" x2="12" y2="12"></line>
          <line x1="12" y1="8" x2="12.01" y2="8"></line>
        </svg>
        <span class="nav-action-text">关于</span>
      </a>
      <!-- 免责声明链接：指向站内免责声明页面 -->
      <a href={`${base}disclaimer/`} class="nav-action-link" title="免责声明">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"></path>
        </svg>
        <span class="nav-action-text">免责声明</span>
      </a>
      <!-- 知识地图链接：指向全局知识地图页面，可视化模块依赖与文档关联关系 -->
      <a href={`${base}map/`} class="nav-action-link" title="知识地图">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <circle cx="6" cy="6" r="2.5"></circle>
          <circle cx="18" cy="6" r="2.5"></circle>
          <circle cx="12" cy="18" r="2.5"></circle>
          <line x1="7.5" y1="7" x2="10.5" y2="16"></line>
          <line x1="16.5" y1="7" x2="13.5" y2="16"></line>
          <line x1="8.5" y1="6" x2="15.5" y2="6"></line>
        </svg>
        <span class="nav-action-text">知识地图</span>
      </a>
      <!-- 学习进度仪表盘链接：指向个人学习进度页面，含文档统计、习题记录、错题集 -->
      <a href={`${base}dashboard/`} class="nav-action-link" title="学习进度">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <rect x="3" y="3" width="7" height="9" rx="1"></rect>
          <rect x="14" y="3" width="7" height="5" rx="1"></rect>
          <rect x="14" y="12" width="7" height="9" rx="1"></rect>
          <rect x="3" y="16" width="7" height="5" rx="1"></rect>
        </svg>
        <span class="nav-action-text">学习进度</span>
      </a>
      <!-- GitHub 仓库链接 -->
      <a
        href="https://github.com/fanquanpp/FANDEX-web"
        class="nav-github-link"
        target="_blank"
        rel="noopener noreferrer"
        title="GitHub 源仓库"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"
          ><path
            d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
          ></path></svg
        >
        <span class="nav-github-text">GitHub 源仓库</span>
      </a>
      <!-- 全屏按钮：仅移动端显示 -->
      <button class="nav-fullscreen-btn" id="home-fullscreen-btn" aria-label="全屏" title="全屏">
        <svg
          width="16"
          height="16"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
        >
          <path
            d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3"
          ></path>
        </svg>
      </button>
      <!-- 主题切换按钮 -->
      <ThemeToggle client:load />
    </div>
  </header>
  <!-- 首页主内容区 -->
  <main class="home-main">
    <slot />
  </main>
</BaseLayout>

<style>
  /* 首页导航栏：固定顶部，毛玻璃背景 */
  .home-nav {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 var(--spacing-md);
    background: var(--color-nav-bg);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    position: sticky;
    top: 0;
    z-index: 100;
    height: var(--nav-height);
  }

  /* 首页主内容区：撑满剩余视口高度 */
  .home-main {
    min-height: calc(100vh - var(--nav-height));
    min-height: calc(100dvh - var(--nav-height));
    overflow-y: auto;
  }

  /* 导航操作链接：方框风格（APP 下载、免责声明） */
  .nav-action-link {
    display: inline-flex;
    align-items: center;
    gap: 4px;
    color: var(--color-text-secondary);
    text-decoration: none;
    font-size: 0.82rem;
    padding: 4px 10px;
    border: 1px solid var(--color-border);
    border-radius: 4px;
    transition:
      color var(--transition-fast),
      border-color var(--transition-fast),
      background var(--transition-fast);
  }
  .nav-action-link:hover {
    color: var(--color-text);
    border-color: var(--color-text-secondary);
    background: var(--color-bg-hover, rgba(128, 128, 128, 0.06));
  }

  /* 移动端隐藏操作链接文字 */
  @media (max-width: 768px) {
    .nav-action-text {
      display: none;
    }
  }

  /* 全屏按钮：默认隐藏，移动端显示 */
  .nav-fullscreen-btn {
    display: none;
    align-items: center;
    justify-content: center;
    background: none;
    border: none;
    padding: 6px;
    cursor: pointer;
    color: var(--color-text-secondary);
    transition: color var(--transition-fast);
  }
  .nav-fullscreen-btn:hover {
    color: var(--color-text);
  }

  /* 移动端适配：显示全屏按钮，隐藏 GitHub 文字 */
  @media (max-width: 768px) {
    .nav-fullscreen-btn {
      display: flex;
    }
    .nav-github-text {
      display: none;
    }
  }
</style>

<script>
  // ========== 全屏模式切换 ==========
  const homeFsBtn = document.getElementById('home-fullscreen-btn');
  if (homeFsBtn) {
    homeFsBtn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(() => {});
      } else {
        document.exitFullscreen().catch(() => {});
      }
    });
    // 监听全屏状态变化并持久化
    document.addEventListener('fullscreenchange', () => {
      if (document.fullscreenElement) {
        try {
          localStorage.setItem('fandex-fullscreen', 'true');
        } catch {}
      } else {
        try {
          localStorage.removeItem('fandex-fullscreen');
        } catch {}
      }
    });
    // 恢复全屏状态
    if (localStorage.getItem('fandex-fullscreen') === 'true' && !document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch(() => {});
    }
  }
</script>
