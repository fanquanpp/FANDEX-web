---
import '@/styles/global.css'
import '@/styles/typography.css'
import '@/styles/code.css'
import '@/styles/components.css'
import ThemeToggle from '@/islands/ThemeToggle.vue'
import { SITE } from '@/lib/constants'

const { title } = Astro.props
const base = import.meta.env.BASE_URL
---

<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <link rel="stylesheet" href={`${base}fonts/fonts.css`} />
    <link rel="preload" href={`${base}fonts/jetbrains-mono-400.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}fonts/jetbrains-mono-700.woff2`} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function() {
        var t = localStorage.getItem('fandex-theme');
        if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          document.documentElement.setAttribute('data-theme', 'dark');
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <header class="home-nav">
      <div class="nav-left">
        <a href={base} class="nav-logo">
          <span class="logo-mark"></span>
          <span class="logo-text">{SITE.title}<span class="logo-home-suffix">-主页</span></span>
        </a>
      </div>
      <div class="nav-right">
        <a href="https://github.com/fanquanpp/FANDEX" class="nav-github-link" target="_blank" rel="noopener noreferrer" title="GitHub源仓库">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="nav-github-text">GitHub源仓库</span>
        </a>
        <ThemeToggle client:load />
      </div>
    </header>
    <main class="home-main">
      <slot />
    </main>
  </body>
</html>

<style>
.home-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacing-md);
  background: var(--color-nav-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 100;
  height: var(--nav-height);
}

.nav-left { display: flex; align-items: center; gap: var(--spacing-sm); }
.nav-right { display: flex; align-items: center; gap: var(--spacing-sm); }
.nav-logo { display: flex; align-items: center; cursor: pointer; }
.nav-logo:hover { opacity: 0.85; }
.nav-github-link {
  display: inline-flex;
  align-items: center;
  gap: 6px;
  padding: 4px 12px;
  border: 1px solid var(--color-border);
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  font-family: var(--font-display);
  font-size: 0.78em;
  font-weight: 500;
  text-decoration: none;
  letter-spacing: 0.02em;
  transition: all var(--transition-fast);
}
.nav-github-link:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}
.nav-github-text {
  white-space: nowrap;
}
@media (max-width: 768px) {
  .nav-github-text {
    display: none;
  }
}
.logo-mark { display: inline-block; width: 8px; height: 28px; background: var(--color-primary); }
.logo-text {
  display: flex; align-items: center; height: 28px; padding: 0 8px;
  background: var(--color-text); color: var(--color-bg);
  font-weight: 700; font-size: 0.8em; font-family: var(--font-display); letter-spacing: 0.1em;
}
.home-main {
  min-height: calc(100vh - var(--nav-height));
  min-height: calc(100dvh - var(--nav-height));
  overflow-y: auto;
}
</style>

<script>
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault()
      const base = document.querySelector('a.nav-logo')?.getAttribute('href') || '/'
      window.location.href = base + 'search'
    }
  })
</script>
