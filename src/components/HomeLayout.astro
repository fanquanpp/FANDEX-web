---
/**
 * 首页布局组件
 * 提供首页的整体结构：顶部导航栏和主内容区
 * 导航栏包含免责声明链接、GitHub 仓库链接、全屏按钮和主题切换
 */
import '@/styles/variables.css'
import '@/styles/global.css'
import '@/styles/typography.css'
import '@/styles/code.css'
import '@/styles/components.css'
import ThemeToggle from '@/islands/ThemeToggle.vue'
import { SITE } from '@/lib/constants'

const { title } = Astro.props
const base = import.meta.env.BASE_URL
---

<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- 内容安全策略 -->
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' data:; img-src 'self' data:; connect-src 'self'" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- CDN 预连接 -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

    <!-- 字体资源预加载 -->
    <link rel="stylesheet" href={`${base}fonts/fonts.css`} />
    <link rel="preload" href={`${base}fonts/jetbrains-mono-400.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}fonts/jetbrains-mono-700.woff2`} as="font" type="font/woff2" crossorigin />
    <!-- 暗色模式初始化：避免页面闪烁 -->
    <script is:inline>
      (function() {
        var raw = localStorage.getItem('fandex-theme');
        var isDark = false;
        if (raw === 'dark' || (!raw && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          isDark = true;
        }
        if (isDark) {
          document.documentElement.setAttribute('data-theme', 'dark');
          document.documentElement.style.colorScheme = 'dark';
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <!-- 首页顶部导航栏 -->
    <header class="home-nav">
      <div class="nav-left">
        <a href={base} class="nav-logo">
          <span class="logo-mark"></span>
          <span class="logo-text">{SITE.title}<span class="logo-home-suffix">-Index</span></span>
        </a>
      </div>
      <div class="nav-right">
        <!-- 速查表链接 -->
        <a href={`${base}cheatsheet/`} class="nav-cheatsheet-link" title="语法速查">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/>
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/>
            <line x1="9" y1="7" x2="15" y2="7"/>
            <line x1="9" y1="11" x2="13" y2="11"/>
          </svg>
          <span class="nav-cheatsheet-text">速查</span>
        </a>
        <!-- 免责声明链接 -->
        <a href={`${base}getting-started/免责声明/`} class="nav-disclaimer-link" title="免责声明">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/>
          </svg>
          <span class="nav-disclaimer-text">免责声明</span>
        </a>
        <!-- GitHub 仓库链接 -->
        <a href="https://github.com/fanquanpp/FANDEX" class="nav-github-link" target="_blank" rel="noopener noreferrer" title="GitHub 源仓库">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/></svg>
          <span class="nav-github-text">GitHub 源仓库</span>
        </a>
        <!-- 全屏按钮：仅移动端显示 -->
        <button class="nav-fullscreen-btn" id="home-fullscreen-btn" aria-label="全屏" title="全屏">
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3" />
          </svg>
        </button>
        <!-- 主题切换按钮 -->
        <ThemeToggle client:load />
      </div>
    </header>
    <!-- 首页主内容区 -->
    <main class="home-main">
      <slot />
    </main>
  </body>
</html>

<style>
/* 首页导航栏：固定顶部，毛玻璃背景 */
.home-nav {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 0 var(--spacing-md);
  background: var(--color-nav-bg);
  backdrop-filter: blur(12px);
  -webkit-backdrop-filter: blur(12px);
  border-bottom: 1px solid var(--color-border);
  position: sticky;
  top: 0;
  z-index: 100;
  height: var(--nav-height);
}

/* 首页主内容区：撑满剩余视口高度 */
.home-main {
  min-height: calc(100vh - var(--nav-height));
  min-height: calc(100dvh - var(--nav-height));
  overflow-y: auto;
}

/* 速查表链接样式 */
.nav-cheatsheet-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--color-text-secondary);
  text-decoration: none;
  font-size: 0.82rem;
  transition: color var(--transition-fast);
}
.nav-cheatsheet-link:hover { color: var(--color-text); }

/* 免责声明链接样式 */
.nav-disclaimer-link {
  display: inline-flex;
  align-items: center;
  gap: 4px;
  color: var(--color-text-secondary);
  text-decoration: none;
  font-size: 0.82rem;
  transition: color var(--transition-fast);
}
.nav-disclaimer-link:hover { color: var(--color-text); }

/* 移动端隐藏速查和免责声明文字 */
@media (max-width: 768px) {
  .nav-cheatsheet-text { display: none; }
  .nav-disclaimer-text { display: none; }
}

/* 全屏按钮：默认隐藏，移动端显示 */
.nav-fullscreen-btn {
  display: none;
  align-items: center;
  justify-content: center;
  background: none;
  border: none;
  padding: 6px;
  cursor: pointer;
  color: var(--color-text-secondary);
  transition: color var(--transition-fast);
}
.nav-fullscreen-btn:hover { color: var(--color-text); }

/* 移动端适配：显示全屏按钮，隐藏 GitHub 文字 */
@media (max-width: 768px) {
  .nav-fullscreen-btn { display: flex; }
  .nav-github-text { display: none; }
}
</style>

<script>
  // 快捷键 Ctrl/Cmd + K 跳转到搜索页
  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault()
      const base = document.querySelector('a.nav-logo')?.getAttribute('href') || '/'
      window.location.href = base + 'search/'
    }
  })

  // ========== 全屏模式切换 ==========
  const homeFsBtn = document.getElementById('home-fullscreen-btn')
  if (homeFsBtn) {
    homeFsBtn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(() => {})
      } else {
        document.exitFullscreen().catch(() => {})
      }
    })
    // 监听全屏状态变化并持久化
    document.addEventListener('fullscreenchange', () => {
      if (document.fullscreenElement) {
        try { localStorage.setItem('fandex-fullscreen', 'true') } catch {}
      } else {
        try { localStorage.removeItem('fandex-fullscreen') } catch {}
      }
    })
    // 恢复全屏状态
    if (localStorage.getItem('fandex-fullscreen') === 'true' && !document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch(() => {})
    }
  }
</script>
