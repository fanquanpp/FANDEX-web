---
import { getCollection } from 'astro:content'
import { getModule, modules, docSlug, categoryColors, getPrimaryCategory } from '@/lib/modules'

const { moduleId, currentSlug, headings, sortedDocs } = Astro.props as {
  moduleId: string
  currentSlug?: string
  headings?: { depth: number; slug: string; text: string }[]
  sortedDocs?: any[]
}

const docs = sortedDocs || await getCollection('docs', ({ data }) => data.module === moduleId)
const sorted = sortedDocs ? docs : docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0))
const meta = getModule(moduleId)

const currentPath = Astro.url.pathname
const base = import.meta.env.BASE_URL
const visibleHeadings = (headings || []).filter((h) => h.depth >= 2 && h.depth <= 3)
const hasHeadings = visibleHeadings.length > 0
---

<aside class="app-sidebar sidebar-component" id="module-sidebar">
  <button class="sidebar-close-btn" id="sidebar-close-btn" aria-label="关闭侧边栏">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
      <line x1="18" y1="6" x2="6" y2="18" />
      <line x1="6" y1="6" x2="18" y2="18" />
    </svg>
  </button>

  <nav class="sidebar-nav">
    <div class="sidebar-top">
      <div class="sidebar-module-header">
        <div class="sidebar-module-title-group">
          <span class="sidebar-module-color-bar" style={`background:${meta ? categoryColors[getPrimaryCategory(meta)] : categoryColors.toolchain}`}></span>
          <span class="sidebar-module-title">{meta?.title || moduleId}</span>
        </div>
        <div class="sidebar-toggle-group" id="sidebar-toggle-group">
          {hasHeadings && (
            <button class="sidebar-toggle-btn active" id="sidebar-toggle-chapters" data-panel="chapters">章节</button>
          )}
          {hasHeadings && (
            <button class="sidebar-toggle-btn" id="sidebar-toggle-outline" data-panel="outline">资料</button>
          )}
        </div>
      </div>

      <a href={base} class="sidebar-back">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3">
          <polyline points="18 6 6 12 18 18" />
        </svg>
        <span>返回首页</span>
      </a>
    </div>

    <div class="sidebar-scroll">
      <div class="sidebar-panel" id="sidebar-panel-chapters">
        <ul class="file-list">
          {sorted.map(doc => {
            const slug = docSlug(doc.id)
            const href = `${base}${moduleId}/${slug}/`
            const isActive = currentSlug && currentSlug === slug
            return (
              <li>
                <a href={href} class={`sidebar-file-link${isActive ? ' active' : ''}`} data-progress-slug={`${moduleId}/${slug}`}>
                  <span class="progress-indicator"></span>
                  {doc.data.title}
                </a>
              </li>
            )
          })}
        </ul>
      </div>

      {hasHeadings && (
        <div class="sidebar-panel" id="sidebar-panel-outline" style="display:none">
          <ul class="outline-list">
            {visibleHeadings.map((h) => (
              <li style={`padding-left: ${(h.depth - 2) * 12}px`}>
                <a href={`#${h.slug}`} class="outline-link" data-outline-slug={h.slug}>{h.text}</a>
              </li>
            ))}
          </ul>
        </div>
      )}

      <div class="sidebar-glossary-link">
        <a href={`${base}${moduleId}/glossary/`} class="sidebar-file-link">
          术语表
        </a>
      </div>
      <div class="sidebar-kmap-link">
        <a href={`${base}${moduleId}/map/`} class="sidebar-file-link">
          知识地图
        </a>
      </div>
    </div>
  </nav>

  <div class="sidebar-all-modules" id="sidebar-all-modules">
    <div class="all-modules-header">
      <div class="all-modules-current">
        <span class="all-modules-current-bar" style={`background:${meta ? categoryColors[getPrimaryCategory(meta)] : categoryColors.toolchain}`}></span>
        <span class="all-modules-current-name">{meta?.title || moduleId}</span>
      </div>
    </div>
    <div class="all-modules-section-title">全部模块</div>
    <ul class="all-modules-list">
      {modules.map(m => (
        <li>
          <a href={`${base}${m.id}/`} class={`all-module-link${m.id === moduleId ? ' current' : ''}`}>
            <span class="all-module-dot" style={`background:${categoryColors[m.categories[0]]}`}></span>
            <span class="all-module-name">{m.title}</span>
          </a>
        </li>
      ))}
    </ul>
  </div>
</aside>

<style>
.sidebar-component {
  display: flex;
  flex-direction: column;
  height: 100%;
}

.sidebar-close-btn {
  display: none;
  align-self: flex-end;
  background: none;
  border: 1px solid var(--color-border-light);
  color: var(--color-text-secondary);
  cursor: pointer;
  padding: 4px;
  line-height: 0;
}

.sidebar-close-btn:hover {
  color: var(--color-text);
  border-color: var(--color-border);
}

.sidebar-nav {
  display: flex;
  flex-direction: column;
  height: 100%;
  min-height: 0;
}

.sidebar-top {
  flex-shrink: 0;
  background: var(--color-bg-sidebar);
}

.sidebar-module-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  margin-bottom: var(--spacing-xs);
}

.sidebar-module-title-group {
  display: flex;
  align-items: center;
  gap: var(--spacing-xs);
  min-width: 0;
}

.sidebar-module-color-bar {
  width: 4px;
  height: 18px;
  border-radius: 2px;
  flex-shrink: 0;
}

.sidebar-module-title {
  font-family: var(--font-display);
  font-size: 0.85em;
  font-weight: 600;
  color: var(--color-text);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sidebar-toggle-group {
  display: flex;
  gap: 0;
  flex-shrink: 0;
}

.sidebar-toggle-btn {
  padding: 2px 8px;
  border: 1px solid var(--color-border);
  border-radius: 0;
  background: transparent;
  color: var(--color-text-secondary);
  font-family: var(--font-display);
  font-size: 0.75em;
  cursor: pointer;
  transition: all var(--transition-fast);
  white-space: nowrap;
}

.sidebar-toggle-modules {
  display: none;
}

.sidebar-toggle-btn:not(:first-child) {
  border-left: none;
}

.sidebar-toggle-btn.active {
  background: var(--color-primary);
  color: #fff;
  border-color: var(--color-primary);
}

.sidebar-toggle-btn.active + .sidebar-toggle-btn {
  border-left-color: var(--color-primary);
}

.sidebar-toggle-btn:not(.active):hover {
  color: var(--color-primary);
}

.sidebar-all-modules {
  display: none;
  padding: var(--spacing-md) 0;
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.sidebar-component.is-modules-view .sidebar-nav {
  display: none;
}

.sidebar-component.is-modules-view .sidebar-all-modules {
  display: block;
}

.sidebar-back {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: 0.8em;
  border-bottom: 1px solid var(--color-border-light);
  margin-bottom: var(--spacing-xs);
}

.sidebar-back:hover {
  color: var(--color-primary);
}

.outline-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.outline-link {
  display: block;
  padding: 3px var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: 0.82em;
  line-height: 1.6;
  transition: color var(--transition-fast);
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.outline-link:hover {
  color: var(--color-primary);
}

.outline-link.active {
  color: var(--color-primary);
  font-weight: 500;
}

.sidebar-glossary-link {
  padding-top: var(--spacing-md);
  border-top: 1px solid var(--color-border-light);
}

.sidebar-kmap-link {
  padding-top: var(--spacing-xs);
}

.all-modules-header {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: var(--spacing-sm) var(--spacing-md);
  border-bottom: 1px solid var(--color-border-light);
}

.all-modules-current {
  display: flex;
  align-items: center;
  gap: 6px;
}

.all-modules-current-bar {
  display: inline-block;
  width: 4px;
  height: 16px;
  border-radius: 2px;
}

.all-modules-current-name {
  font-family: var(--font-display);
  font-size: 0.85em;
  font-weight: 700;
  color: var(--color-text);
}

.all-modules-section-title {
  font-family: var(--font-display);
  font-size: 0.72em;
  font-weight: 600;
  color: var(--color-text-tertiary);
  letter-spacing: 0.05em;
  padding: var(--spacing-sm) var(--spacing-md) var(--spacing-xs);
}

.all-modules-list {
  list-style: none;
  padding: 0;
  margin: 0;
}

.all-module-link {
  display: flex;
  align-items: center;
  gap: 6px;
  padding: 4px var(--spacing-md);
  color: var(--color-text-secondary);
  font-size: 0.82em;
  text-decoration: none;
  transition: color var(--transition-fast), background var(--transition-fast);
}

.all-module-link:hover {
  color: var(--color-primary);
  background: var(--color-bg-hover);
}

.all-module-link.current {
  color: var(--color-primary);
  font-weight: 600;
}

.all-module-dot {
  width: 6px;
  height: 6px;
  border-radius: 50%;
  flex-shrink: 0;
}

.all-module-name {
  white-space: nowrap;
  overflow: hidden;
  text-overflow: ellipsis;
}

.sidebar-scroll {
  flex: 1;
  min-height: 0;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
}

.progress-indicator {
  display: none;
}

.sidebar-file-link.active {
  color: var(--color-primary);
  background: var(--color-bg-hover);
  font-weight: 600;
}

@media (max-width: 768px) {
  .sidebar-close-btn {
    display: block;
  }
}
</style>

<script>
  const sidebar = document.getElementById('module-sidebar') as HTMLElement | null
  const closeBtn = document.getElementById('sidebar-close-btn')
  const chaptersBtn = document.getElementById('sidebar-toggle-chapters')
  const outlineBtn = document.getElementById('sidebar-toggle-outline')
  const chaptersPanel = document.getElementById('sidebar-panel-chapters')
  const outlinePanel = document.getElementById('sidebar-panel-outline')

  function showChapterView() {
    if (sidebar) sidebar.classList.remove('is-modules-view')
    if (chaptersPanel) chaptersPanel.style.display = ''
    if (outlinePanel) outlinePanel.style.display = 'none'
    if (chaptersBtn) chaptersBtn.classList.add('active')
    if (outlineBtn) outlineBtn.classList.remove('active')
  }

  function showOutlineView() {
    if (sidebar) sidebar.classList.remove('is-modules-view')
    if (chaptersPanel) chaptersPanel.style.display = 'none'
    if (outlinePanel) outlinePanel.style.display = ''
    if (chaptersBtn) chaptersBtn.classList.remove('active')
    if (outlineBtn) outlineBtn.classList.add('active')
  }

  function showModulesView() {
    if (sidebar) sidebar.classList.add('is-modules-view')
  }

  if (closeBtn) {
    closeBtn.addEventListener('click', () => {
      document.body.classList.remove('sidebar-open')
    })
  }

  if (chaptersBtn) chaptersBtn.addEventListener('click', showChapterView)
  if (outlineBtn) outlineBtn.addEventListener('click', showOutlineView)

  document.addEventListener('fandex-switch-modules', () => {
    showModulesView()
  })

  document.addEventListener('fandex-switch-chapters', () => {
    showChapterView()
  })

  function updateSidebarProgress() {
    let progress: Record<string, { status: string }> = {}
    try {
      const raw = localStorage.getItem('fandex-progress')
      if (raw) progress = JSON.parse(raw)
    } catch { /* ignore */ }

    document.querySelectorAll('.sidebar-file-link[data-progress-slug]').forEach(link => {
      const el = link as HTMLElement
      const slug = el.getAttribute('data-progress-slug')
      el.classList.remove('progress-done', 'progress-reading')
      if (slug && progress[slug]) {
        const status = progress[slug].status
        if (status === 'done') el.classList.add('progress-done')
        else if (status === 'reading') el.classList.add('progress-reading')
      }
    })
  }

  updateSidebarProgress()
  document.addEventListener('fandex-progress-change', updateSidebarProgress)
  document.addEventListener('astro:page-load', updateSidebarProgress)

  // Save sidebar scroll position before navigation
  const sidebarScroll = document.querySelector('.sidebar-scroll') as HTMLElement | null
  const sidebarFileLinks = document.querySelectorAll('.sidebar-file-link[href]')

  function saveSidebarScroll() {
    if (sidebarScroll) {
      sessionStorage.setItem('fandex-sidebar-scroll', String(sidebarScroll.scrollTop))
    }
  }

  sidebarFileLinks.forEach(link => {
    link.addEventListener('click', saveSidebarScroll)
  })

  // Restore sidebar scroll position after page load
  function restoreSidebarScroll() {
    if (sidebarScroll) {
      const saved = sessionStorage.getItem('fandex-sidebar-scroll')
      if (saved) {
        sidebarScroll.scrollTop = Number(saved)
        sessionStorage.removeItem('fandex-sidebar-scroll')
      }
    }
  }

  restoreSidebarScroll()
  document.addEventListener('astro:page-load', restoreSidebarScroll)

  const outlineLinks = document.querySelectorAll('.outline-link[data-outline-slug]')
  if (outlineLinks.length > 0) {
    const headingElements: HTMLElement[] = []
    outlineLinks.forEach(link => {
      const slug = link.getAttribute('data-outline-slug')
      if (slug) {
        const el = document.getElementById(slug)
        if (el) headingElements.push(el)
      }
    })

    // Outline link click → scroll #app-main to heading
    outlineLinks.forEach(link => {
      link.addEventListener('click', (e) => {
        e.preventDefault()
        const slug = (link as HTMLElement).getAttribute('data-outline-slug')
        if (!slug) return
        const target = document.getElementById(slug)
        if (!target) return
        const main = document.getElementById('app-main')
        if (main) {
          const mainRect = main.getBoundingClientRect()
          const targetRect = target.getBoundingClientRect()
          main.scrollTo({
            top: main.scrollTop + targetRect.top - mainRect.top,
            behavior: 'smooth',
          })
        }
      })
    })

    if (headingElements.length > 0) {
      let activeSlug = ''
      const mainEl = document.getElementById('app-main')
      const observer = new IntersectionObserver(
        (entries) => {
          entries.forEach(entry => {
            if (entry.isIntersecting) {
              activeSlug = entry.target.id
            }
          })
          outlineLinks.forEach(link => {
            const slug = link.getAttribute('data-outline-slug')
            if (slug === activeSlug) {
              link.classList.add('active')
            } else {
              link.classList.remove('active')
            }
          })
        },
        {
          root: mainEl || undefined,
          rootMargin: '0px 0px -60% 0px',
          threshold: 0,
        }
      )
      headingElements.forEach(el => observer.observe(el))
    }
  }
</script>
