---
/**
 * 基础布局组件
 * 抽取 HomeLayout 与 Layout 的共享代码：CSS 引入、CSP meta、CDN 预连接、
 * 字体预加载、暗色模式初始化脚本、主题切换组件、Web Vitals 采集器
 *
 * 设计原则：
 * - 子布局通过 Astro.slots.has() 检测插槽来条件渲染差异化结构
 * - 共享的 head 内容统一通过 named slot "head" 透传
 * - WebVitalsTracker 通过 client:load 在浏览器端水合后开始采集
 */
import '@/styles/variables.css';
import '@/styles/global.css';
import '@/styles/typography.css';
import '@/styles/code.css';
import '@/styles/components.css';
import '@/styles/geo-decor.css';
import '@/styles/tokens.css';
import '@/styles/tailwind.css';
import { SITE } from '@/lib/constants';
import { MAIN_CSP } from '@/lib/csp';
import WebVitalsTracker from '@/islands/WebVitalsTracker.vue';

const base = import.meta.env.BASE_URL;
---

<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <!-- 程序图标：字母 F -->
    <link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
    <link rel="apple-touch-icon" href={`${base}favicon.svg`} />
    <!-- 内容安全策略：限制脚本、样式、字体等资源的加载来源 -->
    <meta http-equiv="Content-Security-Policy" content={MAIN_CSP} />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <!-- 预连接 CDN 以加速资源加载 -->
    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

    <!-- 字体 CSS 异步加载：使用 media=print 技巧避免阻塞首屏渲染
         浏览器会以低优先级加载该样式表，加载完成后切换为 all 媒体应用样式
         配合下方 preload 提前获取字体文件，整体减少 FCP/LCP 阻塞 -->
    <link
      rel="stylesheet"
      href={`${base}fonts/fonts.css`}
      media="print"
      onload="this.media='all'"
    />
    <link
      rel="preload"
      href={`${base}fonts/jetbrains-mono-400.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <link
      rel="preload"
      href={`${base}fonts/jetbrains-mono-700.woff2`}
      as="font"
      type="font/woff2"
      crossorigin
    />
    <!--
      主题初始化脚本（渐进增强策略）
      ==============================
      - 在 HTML 解析早期同步设置 data-theme，防止主题闪烁(FOUC)
      - 始终显式声明 data-theme 为 'light' 或 'dark'，避免 HTML 处于
        "无 data-theme 属性"的中间态（否则 tokens.css 的
        :root:not([data-theme]) 兜底逻辑在 prefers-color-scheme:dark
        下会错误覆盖用户已选择的 light，导致主题切换后刷新被强制回退）
      - ThemeToggle Vue 岛屿通过 client:load 在 hydration 后接管交互
      - 水合失败时页面仍可正常浏览，仅缺少交互式切换按钮
        （用户主题偏好已通过 localStorage 持久化，刷新后保持）
    -->
    <script is:inline>
      (function () {
        var raw = localStorage.getItem('fandex-theme');
        var theme;
        // 优先使用用户手动设置的主题；无保存值时跟随系统偏好
        if (raw === 'dark' || raw === 'light') {
          theme = raw;
        } else {
          theme = window.matchMedia('(prefers-color-scheme: dark)').matches ? 'dark' : 'light';
        }
        // 始终显式设置 data-theme，消除"无属性"中间态
        // 避免 tokens.css 的 :root:not([data-theme]) 兜底逻辑
        // 在 prefers-color-scheme:dark 下错误覆盖用户已选择的 light 主题
        document.documentElement.setAttribute('data-theme', theme);
        document.documentElement.style.colorScheme = theme;
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <slot />
    <!-- Web Vitals 采集器：client:idle 推迟到浏览器空闲时段水合
         采集是观测性任务，不应抢占首屏交互资源；改为 idle 可降低 INP/TBT 开销 -->
    <WebVitalsTracker client:idle />
  </body>
</html>

<script>
  // 代码运行器挂载入口：扫描页面中 div[data-code-runner] 容器并动态挂载 CodeRunner.vue
  // 由 remark-code-runner 插件在 Markdown 渲染期生成容器，惰性加载 Vue 与 CodeRunner 组件
  import { initCodeRunnerMounting } from '@/lib/code-runner-mount';
  initCodeRunnerMounting();
</script>
