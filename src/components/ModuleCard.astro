---
const { mod, color } = Astro.props as { mod: { id: string; title: string; icon: string; description: string; categories: readonly string[] }; color: string }
---

<a href={`${import.meta.env.BASE_URL}${mod.id}/`} class="module-card">
  <span class="card-icon" style={`background:${color}`}>{mod.icon}</span>
  <div class="card-body">
    <h3 class="card-title">{mod.title}</h3>
    <p class="card-desc">{mod.description}</p>
  </div>
</a>

<style>
.module-card {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-sm);
  padding: var(--spacing-lg);
  text-decoration: none;
  background: var(--color-bg);
  transition: transform var(--transition-fast), background var(--transition-fast);
  min-width: 0;
  overflow: hidden;
}

.module-card:hover {
  background: var(--color-bg-hover);
  transform: translateY(-2px);
}

.card-icon {
  width: 36px;
  height: 36px;
  display: flex;
  align-items: center;
  justify-content: center;
  color: #fff;
  font-family: var(--font-display);
  font-weight: 700;
  font-size: 0.75rem;
}

.card-body {
  display: flex;
  flex-direction: column;
  gap: var(--spacing-xs);
}

.card-title {
  font-family: var(--font-display);
  font-size: 0.9rem;
  color: var(--color-text);
  margin: 0;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.card-desc {
  font-size: 0.78rem;
  color: var(--color-text-secondary);
  margin: 0;
  line-height: 1.4;
  overflow: hidden;
  text-overflow: ellipsis;
  display: -webkit-box;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
}

@media (max-width: 768px) {
  .module-card {
    width: 100%;
  }
}
</style>
