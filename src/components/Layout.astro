---
import '@/styles/variables.css'
import '@/styles/global.css'
import '@/styles/typography.css'
import '@/styles/code.css'
import '@/styles/components.css'
import ThemeToggle from '@/islands/ThemeToggle.vue'
import { SITE } from '@/lib/constants'

const { title } = Astro.props
const base = import.meta.env.BASE_URL
const hasSidebar = Astro.slots.has('sidebar')
---

<html lang={SITE.lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta http-equiv="Content-Security-Policy" content="default-src 'self'; script-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; style-src 'self' 'unsafe-inline' https://cdn.jsdelivr.net; font-src 'self' data:; img-src 'self' data:; connect-src 'self'" />
    <meta name="referrer" content="strict-origin-when-cross-origin" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />

    <link rel="stylesheet" href={`${base}fonts/fonts.css`} />
    <link rel="preload" href={`${base}fonts/jetbrains-mono-400.woff2`} as="font" type="font/woff2" crossorigin />
    <link rel="preload" href={`${base}fonts/jetbrains-mono-700.woff2`} as="font" type="font/woff2" crossorigin />
    <script is:inline>
      (function() {
        var raw = localStorage.getItem('fandex-theme');
        var isDark = false;
        if (raw === 'dark' || (!raw && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
          isDark = true;
        }
        if (isDark) {
          document.documentElement.setAttribute('data-theme', 'dark');
          document.documentElement.style.colorScheme = 'dark';
        }
      })();
    </script>
    <slot name="head" />
  </head>
  <body>
    <style is:inline>
      html { height: 100%; }
      body { height: 100vh; height: 100dvh; overflow: hidden; }
    </style>
    {hasSidebar && <div class="sidebar-backdrop" id="sidebar-backdrop"></div>}
    <div class="app-layout" class:list={{ 'no-sidebar': !hasSidebar }}>
      <header class="app-nav">
        <div class="nav-left">
          <a href={base} class="nav-logo">
            <span class="logo-mark"></span>
            <span class="logo-text">{SITE.title}<span class="logo-home-suffix">-Index</span></span>
          </a>
        </div>
        <div class="nav-right">
          <button class="nav-back-to-top" id="nav-back-to-top" aria-label="返回顶部" title="返回顶部">
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
              <polyline points="18 15 12 9 6 15" />
            </svg>
            <span class="nav-back-to-top-text">返回顶部</span>
          </button>
          <ThemeToggle client:load />
        </div>
      </header>
      <slot name="sidebar" />
      <main class="app-main" id="app-main">
        <slot />
      </main>
    </div>
    <nav class="mobile-nav">
      <a href={base} class="mobile-nav-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
          <polyline points="9 22 9 12 15 12 15 22" />
        </svg>
        <span>首页</span>
      </a>
      <a href={`${base}search/`} class="mobile-nav-link">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <line x1="21" y1="21" x2="16.65" y2="16.65" />
        </svg>
        <span>搜索</span>
      </a>
      {hasSidebar && (
        <button class="mobile-nav-link" id="mobile-sidebar-btn" aria-label="模块">
          <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20" />
            <path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z" />
          </svg>
          <span>模块</span>
        </button>
      )}
      <button class="mobile-nav-link" id="mobile-fullscreen-btn" aria-label="全屏">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M8 3H5a2 2 0 0 0-2 2v3m18 0V5a2 2 0 0 0-2-2h-3m0 18h3a2 2 0 0 0 2-2v-3M3 16v3a2 2 0 0 0 2 2h3" />
        </svg>
        <span>全屏</span>
      </button>
    </nav>
  </body>
</html>

<script>
  const backdrop = document.getElementById('sidebar-backdrop')
  const toggle = document.getElementById('nav-toggle')
  const mobileBtn = document.getElementById('mobile-sidebar-btn')

  function openSidebar() {
    document.body.classList.add('sidebar-open')
    syncSidebarUrl()
  }

  function closeSidebar() {
    document.body.classList.remove('sidebar-open')
    syncSidebarUrl()
  }

  function syncSidebarUrl() {
    const params = new URLSearchParams(window.location.search)
    if (document.body.classList.contains('sidebar-open')) {
      params.set('sidebar', '1')
    } else {
      params.delete('sidebar')
    }
    const newSearch = params.toString()
    const newUrl = newSearch
      ? window.location.pathname + '?' + newSearch + window.location.hash
      : window.location.pathname + window.location.hash
    history.replaceState(null, '', newUrl)
  }

  function restoreSidebarFromUrl() {
    const params = new URLSearchParams(window.location.search)
    if (params.get('sidebar') === '1') {
      document.body.classList.add('sidebar-open')
    }
  }

  restoreSidebarFromUrl()

  if (toggle) toggle.addEventListener('click', () => {
    if (document.body.classList.contains('sidebar-open')) {
      closeSidebar()
    } else {
      document.dispatchEvent(new CustomEvent('fandex-switch-chapters'))
      openSidebar()
    }
  })

  if (mobileBtn) mobileBtn.addEventListener('click', () => {
    document.dispatchEvent(new CustomEvent('fandex-switch-modules'))
    openSidebar()
  })

  if (backdrop) backdrop.addEventListener('click', closeSidebar)

  const backToTopBtn = document.getElementById('nav-back-to-top')
  const mainEl = document.getElementById('app-main')
  if (backToTopBtn && mainEl) {
    backToTopBtn.addEventListener('click', () => {
      mainEl.scrollTo({ top: 0, behavior: 'smooth' })
    })
  }

  document.addEventListener('astro:page-load', closeSidebar)

  const fullscreenBtn = document.getElementById('mobile-fullscreen-btn')
  if (fullscreenBtn) {
    fullscreenBtn.addEventListener('click', () => {
      if (!document.fullscreenElement) {
        document.documentElement.requestFullscreen().catch(() => {})
      } else {
        document.exitFullscreen().catch(() => {})
      }
    })
    document.addEventListener('fullscreenchange', () => {
      const span = fullscreenBtn.querySelector('span')
      if (document.fullscreenElement) {
        span && (span.textContent = '退出')
        try { localStorage.setItem('fandex-fullscreen', 'true') } catch {}
      } else {
        span && (span.textContent = '全屏')
        try { localStorage.removeItem('fandex-fullscreen') } catch {}
      }
    })
    // 恢复全屏状态
    if (localStorage.getItem('fandex-fullscreen') === 'true' && !document.fullscreenElement) {
      document.documentElement.requestFullscreen().catch(() => {})
    }
  }

  function initCopyButtons() {
    document.querySelectorAll('pre > code').forEach(codeEl => {
      const pre = codeEl.parentElement
      if (!pre || pre.querySelector('.copy-btn')) return

      const wrapper = document.createElement('div')
      wrapper.className = 'code-block'

      const lang = (codeEl.className.match(/language-(\S+)/) || [])[1] || ''
      if (lang) wrapper.setAttribute('data-lang', lang)

      const btn = document.createElement('button')
      btn.className = 'copy-btn'
      btn.setAttribute('aria-label', 'Copy code')
      btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>'

      btn.addEventListener('click', async () => {
        const text = codeEl.textContent || ''
        try {
          await navigator.clipboard.writeText(text)
          btn.classList.add('copied')
          btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="20 6 9 17 4 12"/></svg>'
          setTimeout(() => {
            btn.classList.remove('copied')
            btn.innerHTML = '<svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>'
          }, 2000)
        } catch {
          const ta = document.createElement('textarea')
          ta.value = text
          ta.style.cssText = 'position:fixed;opacity:0'
          document.body.appendChild(ta)
          ta.select()
          document.execCommand('copy')
          document.body.removeChild(ta)
          btn.classList.add('copied')
          setTimeout(() => btn.classList.remove('copied'), 2000)
        }
      })

      pre.parentNode!.insertBefore(wrapper, pre)
      wrapper.appendChild(pre)
      wrapper.appendChild(btn)
    })
  }

  document.addEventListener('astro:page-load', initCopyButtons)
  initCopyButtons()

  function initMermaid() {
    const mermaidBlocks = document.querySelectorAll('pre[data-language="mermaid"] code, code.language-mermaid')
    if (mermaidBlocks.length === 0) return

    const render = () => {
      const mermaid = (window as any).mermaid
      if (!mermaid) return
      mermaid.initialize({
        startOnLoad: false,
        theme: document.documentElement.getAttribute('data-theme') === 'dark' ? 'dark' : 'default',
        securityLevel: 'strict',
      })
      mermaidBlocks.forEach(async (block, i) => {
        const pre = block.closest('pre')
        if (!pre) return
        const code = block.textContent || ''
        const id = `mermaid-svg-${i}`
        try {
          const { svg } = await mermaid.render(id, code)
          const container = document.createElement('div')
          container.className = 'mermaid-output'
          const purify = (window as any).DOMPurify
          container.innerHTML = purify ? purify.sanitize(svg) : svg
          pre.replaceWith(container)
        } catch {
          const errDiv = document.createElement('div')
          errDiv.className = 'mermaid-error'
          errDiv.textContent = 'Mermaid render failed'
          pre.replaceWith(errDiv)
        }
      })
    }

    if ((window as any).mermaid) {
      render()
      return
    }

    let script = document.getElementById('mermaid-script') as HTMLScriptElement | null
    if (!script) {
      // Load DOMPurify first, then Mermaid
      const loadPurify = new Promise<void>((resolve) => {
        if ((window as any).DOMPurify) { resolve(); return }
        const p = document.createElement('script')
        p.src = 'https://cdn.jsdelivr.net/npm/dompurify@3/dist/purify.min.js'
        p.onload = () => resolve()
        p.onerror = () => resolve() // continue without purify
        document.head.appendChild(p)
      })
      script = document.createElement('script')
      script.id = 'mermaid-script'
      script.src = 'https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js'
      script.onload = () => {
        script!.dataset.loaded = '1'
        loadPurify.then(() => render())
      }
      document.head.appendChild(script)
      return
    }

    if (script.dataset.loaded === '1') {
      render()
      return
    }

    script.addEventListener('load', render, { once: true })
  }

  document.addEventListener('astro:page-load', initMermaid)
  initMermaid()

  async function initTermTooltip() {
    const article = document.querySelector('article.prose')
    if (!article) return
    try {
      const { initTermTooltip: init } = await import('@/lib/term-tooltip')
      await init()
    } catch { /* ignore */ }
  }

  async function initAnimations() {
    try {
      const { setupMicroInteractions } = await import('@/lib/animations')
      setupMicroInteractions()
    } catch { /* ignore */ }
  }

  async function initCodeRunners() {
    try {
      const { initCodeRunners: init } = await import('@/lib/code-runner')
      init()
    } catch { /* ignore */ }
  }

  document.addEventListener('astro:page-load', initTermTooltip)
  document.addEventListener('astro:page-load', initAnimations)
  document.addEventListener('astro:page-load', initCodeRunners)
  initTermTooltip()
  initAnimations()
  initCodeRunners()

  if ('serviceWorker' in navigator) {
    const base = import.meta.env.BASE_URL
    navigator.serviceWorker.register(base + 'sw.js').catch(() => {})
  }

  document.addEventListener('keydown', (e) => {
    if ((e.ctrlKey || e.metaKey) && e.key === 'k') {
      e.preventDefault()
      const base = document.querySelector('a.nav-logo')?.getAttribute('href') || '/'
      window.location.href = base + 'search/'
    }
  })
</script>

<style>
.sidebar-backdrop {
  display: none;
  position: fixed;
  inset: 0;
  top: var(--nav-height);
  background: rgba(0,0,0,0.3);
  z-index: 150;
}
body.sidebar-open .sidebar-backdrop { display: block; }

.nav-toggle { display: none; }

@media (max-width: 768px) {
  .nav-toggle { display: flex; }
}
</style>
