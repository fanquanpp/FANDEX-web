---
import { getCollection } from 'astro:content'

const { moduleId, currentSlug } = Astro.props as { moduleId: string; currentSlug: string }

const docs = await getCollection('docs', ({ data }) => data.module === moduleId)
const sorted = docs.sort((a, b) => (a.data.order || 0) - (b.data.order || 0))

function docSlug(id: string) { return (id.split('/').pop() || id).replace(/\.md$/, '') }

const currentIndex = sorted.findIndex(doc => docSlug(doc.id) === currentSlug)
const prev = currentIndex > 0 ? sorted[currentIndex - 1] : null
const next = currentIndex >= 0 && currentIndex < sorted.length - 1 ? sorted[currentIndex + 1] : null
---

<nav class="doc-nav" class:list={{ 'single-btn': !prev || !next }}>
  {prev ? (
    <a href={`${import.meta.env.BASE_URL}${moduleId}/${docSlug(prev.id)}`} class="nav-btn">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="18 6 6 12 18 18"/></svg>
      <div>
        <span class="nav-label">上一篇</span>
        <span class="nav-title">{prev.data.title}</span>
      </div>
    </a>
  ) : <div></div>}
  {next ? (
    <a href={`${import.meta.env.BASE_URL}${moduleId}/${docSlug(next.id)}`} class="nav-btn" style="text-align:right">
      <div>
        <span class="nav-label">下一篇</span>
        <span class="nav-title">{next.data.title}</span>
      </div>
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="6 6 18 12 6 18"/></svg>
    </a>
  ) : <div></div>}
</nav>

<style>
.doc-nav {
  display: flex;
  justify-content: space-between;
  gap: var(--spacing-md);
  margin-top: var(--spacing-lg);
  padding-top: var(--spacing-lg);
  border-top: 1px solid var(--color-border-light);
  max-width: var(--content-width);
  margin-left: auto;
  margin-right: auto;
}

.nav-btn {
  display: flex;
  align-items: center;
  gap: var(--spacing-sm);
  padding: var(--spacing-sm) var(--spacing-md);
  border: 1px solid var(--color-border);
  background: var(--color-bg-card);
  color: var(--color-text-secondary);
  text-decoration: none;
  flex: 1;
  min-width: 0;
}

.nav-btn:hover {
  border-color: var(--color-primary);
  color: var(--color-primary);
}

.doc-nav.single-btn {
  justify-content: flex-start;
}

.doc-nav.single-btn .nav-btn {
  flex: none;
}

.nav-label {
  font-size: 0.68em;
  color: var(--color-text-tertiary);
  display: block;
}

.nav-title {
  font-size: 0.82em;
  font-weight: 500;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  display: block;
}

@media (max-width: 768px) {
  .doc-nav {
    flex-direction: row;
    gap: var(--spacing-sm);
  }

  .doc-nav.single-btn {
    justify-content: flex-start;
  }

  .doc-nav.single-btn .nav-btn {
    flex: none;
  }

  .nav-btn {
    padding: var(--spacing-xs) var(--spacing-sm);
    flex-direction: row;
  }

  .nav-title {
    font-size: 0.75em;
  }
}
</style>
