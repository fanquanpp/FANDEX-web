      "分组说明": "JavaScript 与网页交互的核心。本组内容涵盖元素查询、创建、事件绑定和样式操作，是前端开发的基本功。",
      "条目": [
        {
          "描述": "查询元素",
          "代码": "// 查询单个元素\nconst btn = document.querySelector('.submit-btn');\nconst title = document.querySelector('#page-title');\n\n// 查询多个元素\nconst items = document.querySelectorAll('.list-item');\nitems.forEach(item => console.log(item.textContent));",
          "高亮代码": "<pre class=\"shiki github-light\" style=\"background-color:#fff;color:#24292e\" tabindex=\"0\"><code><span class=\"line\"><span style=\"color:#6A737D\">// 查询单个元素</span></span>\n<span class=\"line\"><span style=\"color:#D73A49\">const</span><span style=\"color:#005CC5\"> btn</span><span style=\"color:#D73A49\"> =</span><span style=\"color:#24292E\"> document.</span><span style=\"color:#6F42C1\">querySelector</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'.submit-btn'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"><span style=\"color:#D73A49\">const</span><span style=\"color:#005CC5\"> title</span><span style=\"color:#D73A49\"> =</span><span style=\"color:#24292E\"> document.</span><span style=\"color:#6F42C1\">querySelector</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'#page-title'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 查询多个元素</span></span>\n<span class=\"line\"><span style=\"color:#D73A49\">const</span><span style=\"color:#005CC5\"> items</span><span style=\"color:#D73A49\"> =</span><span style=\"color:#24292E\"> document.</span><span style=\"color:#6F42C1\">querySelectorAll</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'.list-item'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">items.</span><span style=\"color:#6F42C1\">forEach</span><span style=\"color:#24292E\">(</span><span style=\"color:#E36209\">item</span><span style=\"color:#D73A49\"> =></span><span style=\"color:#24292E\"> console.</span><span style=\"color:#6F42C1\">log</span><span style=\"color:#24292E\">(item.textContent));</span></span></code></pre>",
          "预期输出": "btn 为匹配的第一个 .submit-btn 元素，items 为所有匹配元素的 NodeList",
          "使用场景": "从 DOM 中查找元素。querySelector 返回第一个匹配元素，querySelectorAll 返回所有匹配元素的 NodeList。支持 CSS 选择器语法。",
          "常见错误": [
            {
              "错误示例": "const items = document.querySelectorAll('.item');\nitems.map(item => ...);",
              "错误信息": "TypeError: items.map is not a function",
              "解决方法": "querySelectorAll 返回 NodeList 而非数组，使用 forEach 或先转换：[...items].map(...)"
            },
            {
              "错误示例": "const el = document.querySelector('.nonexistent');\nel.textContent = 'hello';",
              "错误信息": "TypeError: Cannot set properties of null",
              "解决方法": "查询结果可能为 null，操作前应判断：if (el) { el.textContent = 'hello'; }"
            }
          ],
          "进阶提示": "closest() 方法可向上查找最近的匹配祖先元素：btn.closest('.form-container')。matches() 可判断元素是否匹配选择器。",
          "搜索关键词": ["查询元素", "querySelector", "querySelectorAll", "选择器"]
        },
        {
          "描述": "创建与插入元素",
          "代码": "// 创建元素\nconst li = document.createElement('li');\nli.textContent = '新项目';\nli.setAttribute('class', 'list-item');\n\n// 插入到页面\nconst list = document.querySelector('.list');\nlist.appendChild(li);\n\n// 在指定位置插入\nlist.insertBefore(li, list.firstChild);",
          "高亮代码": "<pre class=\"shiki github-light\" style=\"background-color:#fff;color:#24292e\" tabindex=\"0\"><code><span class=\"line\"><span style=\"color:#6A737D\">// 创建元素</span></span>\n<span class=\"line\"><span style=\"color:#D73A49\">const</span><span style=\"color:#005CC5\"> li</span><span style=\"color:#D73A49\"> =</span><span style=\"color:#24292E\"> document.</span><span style=\"color:#6F42C1\">createElement</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'li'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">li.textContent </span><span style=\"color:#D73A49\">=</span><span style=\"color:#032F62\"> '新项目'</span><span style=\"color:#24292E\">;</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">li.</span><span style=\"color:#6F42C1\">setAttribute</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'class'</span><span style=\"color:#24292E\">, </span><span style=\"color:#032F62\">'list-item'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 插入到页面</span></span>\n<span class=\"line\"><span style=\"color:#D73A49\">const</span><span style=\"color:#005CC5\"> list</span><span style=\"color:#D73A49\"> =</span><span style=\"color:#24292E\"> document.</span><span style=\"color:#6F42C1\">querySelector</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'.list'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">list.</span><span style=\"color:#6F42C1\">appendChild</span><span style=\"color:#24292E\">(li);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 在指定位置插入</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">list.</span><span style=\"color:#6F42C1\">insertBefore</span><span style=\"color:#24292E\">(li, list.firstChild);</span></span></code></pre>",
          "预期输出": "页面中新增一个 li 元素，内容为 '新项目'",
          "使用场景": "动态创建 DOM 元素并插入到页面中。createElement 创建新元素，appendChild 追加到末尾，insertBefore 在指定节点前插入。",
          "常见错误": [
            {
              "错误示例": "const el = document.createElement('div');\ndocument.body.appendChild(el);\ndocument.body.appendChild(el);",
              "错误信息": "元素只会出现一次，appendChild 会移动已有元素而非复制",
              "解决方法": "如需多处插入，使用 cloneNode(true) 创建副本：el.cloneNode(true)"
            },
            {
              "错误示例": "document.querySelector('.container').innerHTML += '<p>新内容</p>';",
              "错误信息": "所有子元素被重新解析，事件监听器丢失，性能差",
              "解决方法": "使用 createElement + appendChild 代替 innerHTML 拼接，避免破坏已有 DOM"
            }
          ],
          "进阶提示": "insertAdjacentHTML/insertAdjacentElement 可在元素的指定位置插入内容：beforebegin、afterbegin、beforeend、afterend。",
          "搜索关键词": ["创建元素", "createElement", "插入元素", "appendChild"]
        },
        {
          "描述": "事件监听",
          "代码": "const btn = document.querySelector('.btn');\n\nfunction handleClick(event) {\n  console.log('按钮被点击', event.target);\n}\n\nbtn.addEventListener('click', handleClick);\n\n// 移除事件监听\nbtn.removeEventListener('click', handleClick);",
          "高亮代码": "<pre class=\"shiki github-light\" style=\"background-color:#fff;color:#24292e\" tabindex=\"0\"><code><span class=\"line\"><span style=\"color:#D73A49\">const</span><span style=\"color:#005CC5\"> btn</span><span style=\"color:#D73A49\"> =</span><span style=\"color:#24292E\"> document.</span><span style=\"color:#6F42C1\">querySelector</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'.btn'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#D73A49\">function</span><span style=\"color:#6F42C1\"> handleClick</span><span style=\"color:#24292E\">(</span><span style=\"color:#E36209\">event</span><span style=\"color:#24292E\">) {</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">  console.</span><span style=\"color:#6F42C1\">log</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'按钮被点击'</span><span style=\"color:#24292E\">, event.target);</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">}</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#24292E\">btn.</span><span style=\"color:#6F42C1\">addEventListener</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'click'</span><span style=\"color:#24292E\">, handleClick);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 移除事件监听</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">btn.</span><span style=\"color:#6F42C1\">removeEventListener</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'click'</span><span style=\"color:#24292E\">, handleClick);</span></span></code></pre>",
          "预期输出": "点击按钮时输出 '按钮被点击' 和被点击的元素",
          "使用场景": "为元素添加事件监听器。addEventListener 比 onclick 属性更灵活，支持同一事件绑定多个处理函数，且可控制冒泡和捕获阶段。",
          "常见错误": [
            {
              "错误示例": "btn.addEventListener('click', () => { ... });\nbtn.removeEventListener('click', () => { ... });",
              "错误信息": "移除失败，因为箭头函数每次创建新引用，与添加时的不是同一个函数",
              "解决方法": "使用具名函数引用：function handler() { ... }; addEventListener('click', handler); removeEventListener('click', handler)"
            },
            {
              "错误示例": "btn.addEventListener('click', handler);\n// 元素被移除后未清理事件监听",
              "错误信息": "可能导致内存泄漏，尤其是闭包中引用了大对象",
              "解决方法": "元素移除前调用 removeEventListener 清理，或使用 AbortController 统一管理"
            }
          ],
          "进阶提示": "事件委托：将监听器绑定到父元素，通过 event.target 判断实际触发的子元素，减少监听器数量，适合动态列表。",
          "搜索关键词": ["事件", "addEventListener", "事件监听", "事件处理"]
        },
        {
          "描述": "classList 样式操作",
          "代码": "const el = document.querySelector('.box');\n\n// 添加类名\nel.classList.add('active');\n\n// 移除类名\nel.classList.remove('hidden');\n\n// 切换类名\nel.classList.toggle('dark-mode');\n\n// 判断是否包含类名\nif (el.classList.contains('active')) {\n  console.log('元素处于激活状态');\n}",
          "高亮代码": "<pre class=\"shiki github-light\" style=\"background-color:#fff;color:#24292e\" tabindex=\"0\"><code><span class=\"line\"><span style=\"color:#D73A49\">const</span><span style=\"color:#005CC5\"> el</span><span style=\"color:#D73A49\"> =</span><span style=\"color:#24292E\"> document.</span><span style=\"color:#6F42C1\">querySelector</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'.box'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 添加类名</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">el.classList.</span><span style=\"color:#6F42C1\">add</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'active'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 移除类名</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">el.classList.</span><span style=\"color:#6F42C1\">remove</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'hidden'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 切换类名</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">el.classList.</span><span style=\"color:#6F42C1\">toggle</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'dark-mode'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"></span>\n<span class=\"line\"><span style=\"color:#6A737D\">// 判断是否包含类名</span></span>\n<span class=\"line\"><span style=\"color:#D73A49\">if</span><span style=\"color:#24292E\"> (el.classList.</span><span style=\"color:#6F42C1\">contains</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'active'</span><span style=\"color:#24292E\">)) {</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">  console.</span><span style=\"color:#6F42C1\">log</span><span style=\"color:#24292E\">(</span><span style=\"color:#032F62\">'元素处于激活状态'</span><span style=\"color:#24292E\">);</span></span>\n<span class=\"line\"><span style=\"color:#24292E\">}</span></span></code></pre>",
          "预期输出": "元素的类名被动态添加、移除或切换",
          "使用场景": "操作元素的 CSS 类名。classList 提供了 add、remove、toggle、contains 等方法，比直接操作 className 字符串更方便和安全。",
          "常见错误": [
            {
              "错误示例": "el.className = 'active';",
              "错误信息": "覆盖了所有已有的类名，导致样式丢失",
              "解决方法": "使用 classList.add('active') 添加类名，不会影响其他已有类名"
            },
            {
              "错误示例": "el.classList.toggle('active', false);（不理解第二个参数）",
              "错误信息": "第二个参数为 false 时强制移除类名，为 true 时强制添加",
              "解决方法": "toggle 的第二个参数是布尔值：true 添加，false 移除，不传则切换"
            }
          ],
          "进阶提示": "classList.add/remove 支持同时操作多个类名：el.classList.add('a', 'b', 'c')。replace('old', 'new') 可替换类名。",
          "搜索关键词": ["样式操作", "classList", "类名", "切换样式"]
        }
      ]
    }
