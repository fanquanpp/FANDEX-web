{
  "name": "fandex",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "循序渐进的自学之旅 — 51 模块 · 1995 篇文档 · 从第一行代码到理解整个世界",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/generate-cheatsheet-highlights.js",
    "build": "node scripts/build-glossary-index.mjs && node scripts/build-search-index.mjs && astro build && pagefind --site dist",
    "preview": "astro preview",
    "prepare": "husky",
    "qa": "node scripts/qa-check.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "type-check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:docs": "remark src/content/docs --ext .md,.mdx",
    "lint:docs:fix": "remark src/content/docs --ext .md,.mdx --output"
  },
  "dependencies": {
    "@astrojs/mdx": "^4.2.0",
    "@astrojs/rss": "^4.0.11",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/vue": "^5.0.0",
    "astro": "^5.5.0",
    "dompurify": "^3.4.11",
    "fuse.js": "^7.3.0",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "vue": "^3.5.0"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "glob": "^13.0.6",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.5",
    "pagefind": "^1.5.2",
    "prettier": "^3.8.3",
    "prettier-plugin-astro": "^0.14.1",
    "remark-cli": "^12.0.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "typescript": "^5.7.0",
    "vitest": "^4.1.7"
  },
  "lint-staged": {
    "*.{astro,ts,js,mjs,css,json,md}": [
      "prettier --write"
    ],
    "*.{ts,astro}": [
      "bash -c 'tsc --noEmit'",
      "bash -c 'astro check'"
    ]
  }
}
