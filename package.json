{
  "name": "fandex",
  "version": "1.1.0",
  "private": true,
  "type": "module",
  "description": "循序渐进的自学之旅 — 51 模块 · 1995 篇文档 · 从第一行代码到理解整个世界",
  "license": "MIT",
  "scripts": {
    "dev": "astro dev",
    "prebuild": "node scripts/generate-cheatsheet-highlights.js",
    "build": "node scripts/build-glossary-index.mjs && node scripts/build-search-index.mjs && astro build",
    "preview": "astro preview",
    "prepare": "husky",
    "qa": "node scripts/qa-check.mjs",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "type-check": "astro check",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint:docs": "remark src/content/docs --ext .md,.mdx",
    "lint:docs:fix": "remark src/content/docs --ext .md,.mdx --output",
    "changeset": "changeset",
    "changeset:version": "changeset version",
    "changeset:status": "changeset status"
  },
  "dependencies": {
    "@astrojs/mdx": "^7.0.3",
    "@astrojs/rss": "^4.0.19",
    "@astrojs/sitemap": "^3.3.0",
    "@astrojs/vue": "^7.0.1",
    "@lucide/vue": "^1.25.0",
    "@tailwindcss/vite": "^4.3.3",
    "astro": "^7.1.1",
    "astro-pagefind": "^2.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "fuse.js": "^7.5.0",
    "radix-vue": "^1.9.17",
    "rehype-autolink-headings": "^7.1.0",
    "rehype-katex": "^7.0.1",
    "rehype-slug": "^6.0.0",
    "remark-emoji": "^5.0.2",
    "remark-gfm": "^4.0.1",
    "remark-math": "^6.0.0",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.3",
    "vue": "^3.5.40",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.9",
    "@changesets/changelog-github": "^0.7.0",
    "@changesets/cli": "^2.31.1",
    "@lhci/cli": "^0.15.1",
    "@playwright/test": "^1.61.1",
    "@testing-library/vue": "^8.1.0",
    "@vitest/coverage-v8": "^4.1.10",
    "@vue/test-utils": "^2.4.11",
    "glob": "^13.0.6",
    "happy-dom": "^20.11.0",
    "husky": "^9.1.7",
    "jsdom": "^29.1.1",
    "lint-staged": "^17.1.0",
    "pagefind": "^1.5.2",
    "prettier": "^3.9.5",
    "prettier-plugin-astro": "^0.14.1",
    "remark-cli": "^12.0.1",
    "remark-preset-lint-consistent": "^6.0.1",
    "rollup-plugin-visualizer": "^7.0.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "lint-staged": {
    "*.{astro,ts,js,mjs,css,json,md}": [
      "prettier --write"
    ],
    "*.{ts,astro}": [
      "bash -c 'tsc --noEmit'",
      "bash -c 'astro check'"
    ]
  }
}
